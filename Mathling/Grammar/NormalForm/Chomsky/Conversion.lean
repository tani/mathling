# Mathling / Grammar / NormalForm / Chomsky / Conversion モジュール

任意の文脈自由文法を、fresh start、ε 規則除去、unit 規則除去、終端記号分離、二分化の順に変換して Chomsky 標準形を得る。各段階で規則形状と導出の双方向シミュレーションを分離し、最終的な言語保存と初期記号不変条件を合成する。

```lean
@[expose] public section

/-!
# Chomsky normal form

Constructive conversion of Mathlib context-free grammars to Chomsky normal form.
-/

namespace Mathling.Grammar

namespace ChomskyNormalGrammar

variable {T : Type*}

/-- The language generated by a Chomsky-normal grammar. -/
def language (g : ChomskyNormalGrammar T) : Language T := g.cfg.language

/-- Forget the Chomsky-normality evidence. -/
def toContextFreeGrammar (g : ChomskyNormalGrammar T) : ContextFreeGrammar T := g.cfg

@[grind =, simp] theorem toContextFreeGrammar_language (g : ChomskyNormalGrammar T) :
    g.toContextFreeGrammar.language = g.language := rfl

/-- Proof-only compatibility for consumers of an arbitrary CNF grammar.
Executable conversions expose a concrete `LinearOrder`, which takes precedence. -/
noncomputable instance (priority := low) cnfNonterminalDecidableEq
    (g : ChomskyNormalGrammar T) : DecidableEq g.cfg.NT :=
  Classical.decEq _

end ChomskyNormalGrammar

namespace ContextFreeGrammar

@[grind cases] inductive FreshStartNT (N : Type*) where
  | start
  | old (A : N)
deriving DecidableEq, Repr

def FreshStartNT.orderKey : FreshStartNT N → Unit ⊕ₗ N
  | .start => Sum.inlₗ ()
  | .old A => Sum.inrₗ A

instance [LinearOrder N] : LinearOrder (FreshStartNT N) :=
  LinearOrder.lift' FreshStartNT.orderKey (by
    intro x y h
    cases x <;> cases y <;> simp_all [FreshStartNT.orderKey])

instance [LinearOrder T] [LinearOrder N] : LinearOrder (Symbol T N) :=
  LinearOrder.lift'
    (fun x : Symbol T N => match x with
      | .terminal a => Sum.inlₗ a
      | .nonterminal A => Sum.inrₗ A)
    (by intro x y h; cases x <;> cases y <;> simp_all)

instance [LinearOrder T] [LinearOrder N] :
    LinearOrder (ContextFreeRule T N) :=
  LinearOrder.lift'
    (fun r : ContextFreeRule T N =>
      (toLex (r.input, r.output) : N ×ₗ List (Symbol T N))) (by
    intro x y h
    cases x
    cases y
    simp_all)

```

## 型 `FreshStartNT` の線形順序から fresh-start 規則の構成へ

前段で `FreshStartNT`・`Symbol`・`ContextFreeRule` に対する `LinearOrder` インスタンスを整えたのは、以降のステージ（nullable 集合や unit 到達可能性集合の計算）が `Finset.powerset` や有限集合上の決定可能な比較を要求する演算に依存するためである。ここから先は、その基盤の上に実際の変換の最初の一手——新しい開始記号 $`S_0`$ を導入し、$`S_0 \to S`$ という単一規則を追加した文法 `freshStart`——を定義する。この構成が「元の開始記号がどの規則の右辺にも現れない」という後続段の不変条件の出発点になる。

```lean
def freshStartRule {T N : Type*} (S : N) :
    ContextFreeRule T (FreshStartNT N) :=
  { input := .start, output := [Symbol.nonterminal (.old S)] }

def freshStartRules (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] :
    Finset (ContextFreeRule T (FreshStartNT g.NT)) :=
  insert (freshStartRule g.initial)
    (g.rules.image fun r => ContextFreeRule.mapNonterminal FreshStartNT.old r)

def freshStart (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] : ContextFreeGrammar T :=
  { NT := FreshStartNT g.NT
    initial := .start
    rules := freshStartRules g }

@[grind =, simp] private theorem freshStart_initial (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] :
    (freshStart g).initial = FreshStartNT.start := rfl

@[grind] theorem mem_freshStart_rules (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    (r : ContextFreeRule T (FreshStartNT g.NT)) :
    r ∈ freshStartRules g ↔
      r = freshStartRule g.initial ∨
        ∃ oldRule ∈ g.rules,
          ContextFreeRule.mapNonterminal FreshStartNT.old oldRule = r := by
  classical
  change r ∈ insert (freshStartRule g.initial)
    (g.rules.image fun oldRule =>
      ContextFreeRule.mapNonterminal FreshStartNT.old oldRule) ↔ _
  rw [Finset.mem_insert, Finset.mem_image]

@[grind] theorem oldSymbols_not_start {T N : Type*}
    (xs : List (Symbol T N)) :
    Symbol.nonterminal (FreshStartNT.start : FreshStartNT N) ∉
      xs.map (Symbol.mapNonterminal FreshStartNT.old) := by
  induction xs with
  | nil => simp
  | cons x xs ih =>
      cases x <;> simp_all

@[grind] theorem freshStart_initial_not_output (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] :
    ∀ r ∈ (freshStart g).rules,
      Symbol.nonterminal (freshStart g).initial ∉ r.output := by
  classical
  intro r hr
  change ContextFreeRule T (FreshStartNT g.NT) at r
  change r ∈ freshStartRules g at hr
  change Symbol.nonterminal FreshStartNT.start ∉ r.output
  rw [mem_freshStart_rules] at hr
  rcases hr with rfl | ⟨oldRule, _, rfl⟩
  · simp [freshStartRule]
  · simpa [ContextFreeRule.mapNonterminal] using
      oldSymbols_not_start oldRule.output

```

## fresh start の消去写像と導出シミュレーション

追加した初期記号を元の初期記号へ戻す写像を定義し、fresh-start 文法の一歩の書換えを元文法の導出へ移す。自己書換えの補助事実を介して、両方向の言語保存を組み立てる。

```lean
def eraseFreshStart (S : N) : FreshStartNT N → N
  | .start => S
  | .old A => A

@[grind =, simp] private theorem eraseFreshStart_start (S : N) :
    eraseFreshStart S (FreshStartNT.start : FreshStartNT N) = S := rfl

@[grind =, simp] private theorem eraseFreshStart_old_symbol {T N : Type*} (S : N)
    (x : Symbol T N) :
    Symbol.mapNonterminal (eraseFreshStart S)
      (Symbol.mapNonterminal FreshStartNT.old x) = x := by
  cases x <;> rfl

@[grind =, simp] private theorem eraseFreshStart_start_symbol {T N : Type*} (S : N) :
    Symbol.mapNonterminal (eraseFreshStart S)
      (Symbol.nonterminal (FreshStartNT.start : FreshStartNT N)) =
        (Symbol.nonterminal S : Symbol T N) := rfl

@[grind =, simp] private theorem eraseFreshStart_terminal_symbol {T N : Type*}
    (S : N) (a : T) :
    Symbol.mapNonterminal (eraseFreshStart S)
      (Symbol.terminal a : Symbol T (FreshStartNT N)) =
        (Symbol.terminal a : Symbol T N) := rfl

@[grind =, simp] private theorem freshStart_old_terminal_symbol {T N : Type*} (a : T) :
    Symbol.mapNonterminal FreshStartNT.old (Symbol.terminal a : Symbol T N) =
      (Symbol.terminal a : Symbol T (FreshStartNT N)) := rfl

@[grind] theorem freshStart_forward_step (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] {u v}
    (h : g.Produces u v) :
    (freshStart g).Derives
      (u.map (Symbol.mapNonterminal FreshStartNT.old))
      (v.map (Symbol.mapNonterminal FreshStartNT.old)) := by
  classical
  rcases h with ⟨r, hr, hrewrite⟩
  apply ContextFreeGrammar.Produces.single
  refine ⟨ContextFreeRule.mapNonterminal FreshStartNT.old r, ?_,
    Mathling.Grammar.ContextFreeRule.Rewrites.mapNonterminal
      hrewrite FreshStartNT.old⟩
  change ContextFreeRule.mapNonterminal FreshStartNT.old r ∈ freshStartRules g
  rw [mem_freshStart_rules]
  exact Or.inr ⟨r, hr, rfl⟩

@[grind] theorem rewrite_self_eq {T N : Type*} {A : N}
    {u v : List (Symbol T N)}
    (h : ({ input := A, output := [Symbol.nonterminal A] } :
      ContextFreeRule T N).Rewrites u v) : u = v := by
  obtain ⟨p, q, rfl, rfl⟩ := h.exists_parts
  simp

@[grind] theorem freshStart_reverse_step (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    {u v : List (Symbol T (FreshStartNT g.NT))}
    (h : (freshStart g).Produces u v) :
    g.Derives
      (u.map (Symbol.mapNonterminal (eraseFreshStart g.initial)))
      (v.map (Symbol.mapNonterminal (eraseFreshStart g.initial))) := by
  classical
  rcases h with ⟨r, hr, hrewrite⟩
  change ContextFreeRule T (FreshStartNT g.NT) at r
  change r ∈ freshStartRules g at hr
  rw [mem_freshStart_rules] at hr
  rcases hr with rfl | ⟨oldRule, hold, rfl⟩
  · have heq := rewrite_self_eq
      (Mathling.Grammar.ContextFreeRule.Rewrites.mapNonterminal
        hrewrite (eraseFreshStart g.initial))
    exact heq ▸ ContextFreeGrammar.Derives.refl _
  · apply ContextFreeGrammar.Produces.single
    refine ⟨oldRule, hold, ?_⟩
    have hcomp :
        (Symbol.mapNonterminal (eraseFreshStart g.initial) ∘
          Symbol.mapNonterminal FreshStartNT.old :
          Symbol T g.NT → Symbol T g.NT) = id := by
      funext x
      exact eraseFreshStart_old_symbol g.initial x
    have hrule :
        ContextFreeRule.mapNonterminal (eraseFreshStart g.initial)
          (ContextFreeRule.mapNonterminal FreshStartNT.old oldRule) = oldRule := by
      cases oldRule
      simp [ContextFreeRule.mapNonterminal, List.map_map, hcomp, eraseFreshStart]
    have hmapped :=
      Mathling.Grammar.ContextFreeRule.Rewrites.mapNonterminal
        hrewrite (eraseFreshStart g.initial)
    exact hrule ▸ hmapped

```

## 単一ステップの往復から導出全体の言語保存へ

ここまでで `freshStart_forward_step` と `freshStart_reverse_step` により、`g` の一手の書き換えと `freshStart g` の一手の書き換えが `FreshStartNT.old`／`eraseFreshStart` を介して一対一に対応することを確認した。次の `freshStart_language` は、この単一ステップの対応を `Derives`（反射推移閉包）へ持ち上げ、開始記号からの脱糖を追跡することで $`(\mathrm{freshStart}\ g).\mathrm{language} = g.\mathrm{language}`$ という同値を証明する。この等式がパイプライン全体を貫く `calc` 連鎖の最初の一段となる。

```lean
@[grind] theorem freshStart_language (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] :
    (freshStart g).language = g.language := by
  ext w
  constructor
  · intro hw
    have h := ContextFreeGrammar.derives_lift_of_produces
      (freshStart_reverse_step g) hw
    rw [freshStart_initial] at h
    have hroot :
        [(Symbol.mapNonterminal (eraseFreshStart g.initial)
          (Symbol.nonterminal (FreshStartNT.start : FreshStartNT g.NT)) :
            Symbol T g.NT)] =
        [(Symbol.nonterminal g.initial : Symbol T g.NT)] := by rfl
    have hyield :
        List.map (Symbol.mapNonterminal (eraseFreshStart g.initial))
          (List.map (Symbol.terminal : T → Symbol T (FreshStartNT g.NT)) w) =
        List.map (Symbol.terminal : T → Symbol T g.NT) w := by
      induction w with
      | nil => rfl
      | cons a w ih => simp [Symbol.mapNonterminal, ih]
    change g.Derives [Symbol.nonterminal g.initial] (List.map Symbol.terminal w)
    exact hroot ▸ hyield ▸ h
  · intro hw
    have hold := ContextFreeGrammar.derives_lift_of_produces
      (freshStart_forward_step g) hw
    have hstart : (freshStart g).Produces
        [Symbol.nonterminal (freshStart g).initial]
        [Symbol.nonterminal (FreshStartNT.old g.initial)] := by
      refine ⟨freshStartRule g.initial, ?_,
        ContextFreeRule.Rewrites.input_output⟩
      change freshStartRule g.initial ∈ freshStartRules g
      rw [mem_freshStart_rules]
      exact Or.inl rfl
    exact hstart.single.trans (by
      have hroot :
          List.map (Symbol.mapNonterminal FreshStartNT.old)
            [(Symbol.nonterminal g.initial : Symbol T g.NT)] =
          [(Symbol.nonterminal (FreshStartNT.old g.initial) :
            Symbol T (FreshStartNT g.NT))] := by rfl
      have hyield :
          List.map (Symbol.mapNonterminal FreshStartNT.old)
            (List.map (Symbol.terminal : T → Symbol T g.NT) w) =
          List.map (Symbol.terminal : T → Symbol T (FreshStartNT g.NT)) w := by
        induction w with
        | nil => rfl
        | cons a w ih => simp [Symbol.mapNonterminal, ih]
      exact hroot ▸ hyield ▸ hold)


/-! ## Elimination of non-initial empty productions -/

```

## nullable 非終端記号の有限閉包

空語を導出できる非終端記号を意味論的に定義し、有限集合上の閉包計算で近似する。右辺が現在の集合だけから空になれるかを判定し、反復計算の健全性と完全性を分離して証明する。

```lean
def Nullable (g : ContextFreeGrammar T) (A : g.NT) : Prop :=
  g.Derives [Symbol.nonterminal A] []

/-- Whether every symbol in a right-hand side is a nonterminal already known
to be nullable. -/
def rhsNullableIn [DecidableEq N] (S : Finset N) :
    List (Symbol T N) → Bool
  | [] => true
  | .terminal _ :: _ => false
  | .nonterminal A :: xs => decide (A ∈ S) && rhsNullableIn S xs

/-- A finite set is closed under nullable productions. -/
def nullableClosed (g : ContextFreeGrammar T) [DecidableEq T]
    [DecidableEq g.NT] (S : Finset g.NT) : Bool :=
  decide (g.rules.filter (fun r =>
    rhsNullableIn S r.output = true ∧ r.input ∉ S) = ∅)

/-- The least nullable-closed subset of the grammar's finite support.

This finite powerset presentation is executable and characterizes the same
least fixed point as iterative saturation. -/
def nullableSet (g : ContextFreeGrammar T) [DecidableEq T]
    [DecidableEq g.NT] : Finset g.NT :=
  let support := activeNonterminals g
  let closed := support.powerset.filter fun S => nullableClosed g S = true
  support.filter fun A => closed.filter (fun S => A ∉ S) = ∅

@[grind] theorem nullableClosed_eq_true (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] {S : Finset g.NT} :
    nullableClosed g S = true ↔
      ∀ r ∈ g.rules, rhsNullableIn S r.output = true → r.input ∈ S := by
  simp only [nullableClosed, decide_eq_true_eq, Finset.filter_eq_empty_iff]
  constructor
  · intro h r hr hout
    by_contra hin
    exact h hr ⟨hout, hin⟩
  · intro h r hr hbad
    exact hbad.2 (h r hr hbad.1)

@[grind] theorem nullable_mem_of_closed (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] {S : Finset g.NT}
    (hclosed : nullableClosed g S = true) {A : g.NT}
    (hA : Nullable g A) : A ∈ S := by
  have htree := derivationFormTree_of_derives g (w := []) hA
  have hall : rhsNullableIn S [Symbol.nonterminal A] = true :=
    DerivationFormTree.rec
    (motive_1 := fun x w _ =>
      w = [] → match x with
        | .terminal _ => False
        | .nonterminal B => B ∈ S)
    (motive_2 := fun xs w _ =>
      w = [] → rhsNullableIn S xs = true)
    (fun _ h => by simp at h)
    (fun r hr _ _ ih hnil =>
      (nullableClosed_eq_true g).mp hclosed r hr (ih hnil))
    (fun _ => by simp [rhsNullableIn])
    (fun {x} {u} {xs} {v} _ _ ihHead ihTail hnil => by
      obtain ⟨hhead, htail⟩ := List.append_eq_nil_iff.mp hnil
      cases x with
      | terminal a => exact (ihHead hhead).elim
      | nonterminal B =>
          simp only [rhsNullableIn, Bool.and_eq_true, decide_eq_true_eq]
          exact ⟨ihHead hhead, ihTail htail⟩)
    htree rfl
  simpa [rhsNullableIn] using hall

@[grind] theorem derives_nil_of_rhsNullableIn (g : ContextFreeGrammar T)
    [DecidableEq g.NT] {S : Finset g.NT}
    (hS : ∀ A ∈ S, Nullable g A) :
    ∀ {xs : List (Symbol T g.NT)}, rhsNullableIn S xs = true →
      g.Derives xs [] := by
  intro xs hxs
  induction xs with
  | nil => exact ContextFreeGrammar.Derives.refl []
  | cons x xs ih =>
      cases x with
      | terminal a => simp [rhsNullableIn] at hxs
      | nonterminal A =>
          simp only [rhsNullableIn, Bool.and_eq_true, decide_eq_true_eq] at hxs
          exact (hS A hxs.1).append_right xs |>.trans (ih hxs.2)

```

## nullable 閉包の健全性から `nullableSet` の完全性へ

ここまでで、`nullableClosed` によって特徴づけられる閉包性と、実際に空列を導出できることとの二方向の関係——閉集合はすべての nullable 非終端記号を含むこと（`nullable_mem_of_closed`）、および `rhsNullableIn` を満たす右辺は実際に $`\varepsilon`$ へ導出できること（`derives_nil_of_rhsNullableIn`）——を確立した。残るは `nullableSet g` が文法の有限台 `activeNonterminals g` に収まることを確認したうえで、最小不動点としての `nullableSet` の構成が意味論的な `Nullable` 述語と完全に一致することを証明する `mem_nullableSet_iff` である。この一致が、以降の ε-規則除去で「どの非終端記号を消去してよいか」を決定可能にする。

```lean
@[grind] theorem nullable_mem_activeNonterminals (g : ContextFreeGrammar T)
    [DecidableEq g.NT] {A : g.NT} (hA : Nullable g A) :
    A ∈ activeNonterminals g := by
  rcases hA.eq_or_head with heq | ⟨v, hstep, _⟩
  · simp at heq
  · rcases hstep with ⟨r, hr, hrewrite⟩
    obtain ⟨p, q, hsource, _⟩ := hrewrite.exists_parts
    have hinput : r.input = A := by
      have hmem :
          (Symbol.nonterminal r.input : Symbol T g.NT) ∈
            p ++ [Symbol.nonterminal r.input] ++ q := by simp
      rw [← hsource] at hmem
      simpa using hmem
    rw [← hinput]
    exact rule_input_mem_activeNonterminals g hr

/-- The executable nullable-set computation agrees with semantic nullability. -/
@[grind] theorem mem_nullableSet_iff (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] {A : g.NT} :
    A ∈ nullableSet g ↔ Nullable g A := by
  classical
  let semantic := (activeNonterminals g).filter fun B => Nullable g B
  have hsemantic_closed : nullableClosed g semantic = true := by
    rw [nullableClosed_eq_true]
    intro r hr hrhs
    apply Finset.mem_filter.mpr
    refine ⟨rule_input_mem_activeNonterminals g hr, ?_⟩
    exact ContextFreeGrammar.Produces.single
      ⟨r, hr, ContextFreeRule.Rewrites.input_output⟩ |>.trans
        (derives_nil_of_rhsNullableIn g
          (fun B hB => (Finset.mem_filter.mp hB).2) hrhs)
  constructor
  · intro hA
    simp only [nullableSet, Finset.mem_filter] at hA
    have hsemPower : semantic ∈ (activeNonterminals g).powerset :=
      Finset.mem_powerset.mpr fun B hB => (Finset.mem_filter.mp hB).1
    have hsemClosed :
        semantic ∈ (activeNonterminals g).powerset.filter
          (fun S => nullableClosed g S = true) :=
      Finset.mem_filter.mpr ⟨hsemPower, hsemantic_closed⟩
    have hnotMissing : semantic ∉
        ((activeNonterminals g).powerset.filter
          (fun S => nullableClosed g S = true)).filter (fun S => A ∉ S) := by
      simpa [hsemClosed] using congrArg (fun s => semantic ∉ s) hA.2
    by_contra hnullable
    exact hnotMissing (Finset.mem_filter.mpr
      ⟨hsemClosed, by simpa [semantic, hnullable]⟩)
  · intro hnullable
    refine Finset.mem_filter.mpr
      ⟨nullable_mem_activeNonterminals g hnullable, ?_⟩
    apply Finset.filter_eq_empty_iff.mpr
    intro S hS hmissing
    exact hmissing (nullable_mem_of_closed g
      (Finset.mem_filter.mp hS).2 hnullable)

```

## 空語判定と nullable variant

初期記号の nullable 性を Boolean に落とし、規則右辺から nullable 記号を選択的に削除した全 variant を列挙する。元の記号順序を保った部分列だけを生成することが重要な不変条件である。

```lean
/-- Executably decide whether a finite context-free grammar generates the empty
word. -/
def hasEmptyWord (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] : Bool :=
  decide (g.initial ∈ nullableSet g)

@[grind =, simp] theorem hasEmptyWord_eq_true_iff (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] :
    hasEmptyWord g = true ↔ [] ∈ g.language := by
  rw [hasEmptyWord, decide_eq_true_eq, mem_nullableSet_iff]
  rfl

def nullableVariants (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] :
    List (Symbol T g.NT) → Finset (List (Symbol T g.NT))
  | [] => {[]}
  | Symbol.terminal a :: xs =>
      (nullableVariants g xs).image (Symbol.terminal a :: ·)
  | Symbol.nonterminal A :: xs =>
      let kept :=
        (nullableVariants g xs).image (Symbol.nonterminal A :: ·)
      if A ∈ nullableSet g then
        kept ∪ nullableVariants g xs
      else kept

@[grind] theorem self_mem_nullableVariants (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    (xs : List (Symbol T g.NT)) : xs ∈ nullableVariants g xs := by
  classical
  induction xs with
  | nil => simp [nullableVariants]
  | cons x xs ih =>
      cases x with
      | terminal a => simp [nullableVariants, ih]
      | nonterminal A =>
          simp only [nullableVariants]
          split <;> simp [ih]

@[grind] theorem derives_of_mem_nullableVariants (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] :
    ∀ {rhs rhs' : List (Symbol T g.NT)},
      rhs' ∈ nullableVariants g rhs → g.Derives rhs rhs' := by
  classical
  intro rhs
  induction rhs with
  | nil =>
      intro rhs' h
      simp only [nullableVariants, Finset.mem_singleton] at h
      subst rhs'
      exact ContextFreeGrammar.Derives.refl []
  | cons x xs ih =>
      intro rhs' h
      cases x with
      | terminal a =>
          simp only [nullableVariants] at h
          obtain ⟨ys, hys, rfl⟩ := Finset.mem_image.mp h
          simpa using (ih hys).append_left [Symbol.terminal a]
      | nonterminal A =>
          simp only [nullableVariants] at h
          split at h
          next hnullable =>
            rcases Finset.mem_union.mp h with hkeep | hdrop
            · obtain ⟨ys, hys, rfl⟩ := Finset.mem_image.mp hkeep
              simpa using (ih hys).append_left [Symbol.nonterminal A]
            · exact (((mem_nullableSet_iff g).mp hnullable).append_right xs).trans
                (ih hdrop)
          next =>
            obtain ⟨ys, hys, rfl⟩ := Finset.mem_image.mp h
            simpa using (ih hys).append_left [Symbol.nonterminal A]

@[grind] theorem mem_nullableVariants_append (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    {xs ys zs : List (Symbol T g.NT)} :
    zs ∈ nullableVariants g (xs ++ ys) ↔
      ∃ xs' ∈ nullableVariants g xs,
        ∃ ys' ∈ nullableVariants g ys, zs = xs' ++ ys' := by
  classical
  induction xs generalizing zs with
  | nil => simp [nullableVariants]
  | cons x xs ih =>
      cases x with
      | terminal a =>
          simp only [List.cons_append, nullableVariants]
          constructor
          · intro h
            obtain ⟨zs', hzs', rfl⟩ := Finset.mem_image.mp h
            obtain ⟨xs', hxs', ys', hys', rfl⟩ := ih.mp hzs'
            exact ⟨Symbol.terminal a :: xs',
              Finset.mem_image.mpr ⟨xs', hxs', rfl⟩,
              ys', hys', rfl⟩
          · rintro ⟨xs', hxs', ys', hys', rfl⟩
            obtain ⟨tail, htail, rfl⟩ := Finset.mem_image.mp hxs'
            apply Finset.mem_image.mpr
            exact ⟨tail ++ ys', ih.mpr ⟨tail, htail, ys', hys', rfl⟩,
              by simp⟩
      | nonterminal A =>
          simp only [List.cons_append, nullableVariants]
          split
          next hnullable =>
            constructor
            · intro h
              rcases Finset.mem_union.mp h with hkeep | hdrop
              · obtain ⟨zs', hzs', rfl⟩ := Finset.mem_image.mp hkeep
                obtain ⟨xs', hxs', ys', hys', rfl⟩ := ih.mp hzs'
                exact ⟨Symbol.nonterminal A :: xs',
                  Finset.mem_union.mpr (Or.inl
                    (Finset.mem_image.mpr ⟨xs', hxs', rfl⟩)),
                  ys', hys', rfl⟩
              · obtain ⟨xs', hxs', ys', hys', rfl⟩ := ih.mp hdrop
                exact ⟨xs', Finset.mem_union.mpr (Or.inr hxs'),
                  ys', hys', rfl⟩
            · rintro ⟨xs', hxs', ys', hys', rfl⟩
              rcases Finset.mem_union.mp hxs' with hkeep | hdrop
              · obtain ⟨tail, htail, rfl⟩ := Finset.mem_image.mp hkeep
                apply Finset.mem_union.mpr
                left
                apply Finset.mem_image.mpr
                exact ⟨tail ++ ys',
                  ih.mpr ⟨tail, htail, ys', hys', rfl⟩, by simp⟩
              · apply Finset.mem_union.mpr
                right
                exact ih.mpr ⟨xs', hdrop, ys', hys', rfl⟩
          next hnotnullable =>
            constructor
            · intro h
              obtain ⟨zs', hzs', rfl⟩ := Finset.mem_image.mp h
              obtain ⟨xs', hxs', ys', hys', rfl⟩ := ih.mp hzs'
              exact ⟨Symbol.nonterminal A :: xs',
                Finset.mem_image.mpr ⟨xs', hxs', rfl⟩,
                ys', hys', rfl⟩
            · rintro ⟨xs', hxs', ys', hys', rfl⟩
              obtain ⟨tail, htail, rfl⟩ := Finset.mem_image.mp hxs'
              apply Finset.mem_image.mpr
              exact ⟨tail ++ ys',
                ih.mpr ⟨tail, htail, ys', hys', rfl⟩, by simp⟩

```

## ε 規則除去文法の構成

variant の所属補題を確立した後、非初期の空右辺を除外した規則集合を構成する。元言語が空語を含む場合だけ fresh start から ε を許し、それ以外の規則形状を保つ。

```lean
@[grind] theorem mem_of_mem_nullableVariants (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    {xs ys : List (Symbol T g.NT)}
    (hys : ys ∈ nullableVariants g xs) {x : Symbol T g.NT}
    (hx : x ∈ ys) : x ∈ xs := by
  classical
  induction xs generalizing ys with
  | nil =>
      simp [nullableVariants] at hys
      subst ys
      simp at hx
  | cons y xs ih =>
      cases y with
      | terminal a =>
          simp only [nullableVariants] at hys
          obtain ⟨tail, htail, rfl⟩ := Finset.mem_image.mp hys
          rcases List.mem_cons.mp hx with rfl | hx
          · simp
          · exact List.mem_cons_of_mem _ (ih htail hx)
      | nonterminal A =>
          simp only [nullableVariants] at hys
          split at hys
          next =>
            rcases Finset.mem_union.mp hys with hkeep | hdrop
            · obtain ⟨tail, htail, rfl⟩ := Finset.mem_image.mp hkeep
              rcases List.mem_cons.mp hx with rfl | hx
              · simp
              · exact List.mem_cons_of_mem _ (ih htail hx)
            · exact List.mem_cons_of_mem _ (ih hdrop hx)
          next =>
            obtain ⟨tail, htail, rfl⟩ := Finset.mem_image.mp hys
            rcases List.mem_cons.mp hx with rfl | hx
            · simp
            · exact List.mem_cons_of_mem _ (ih htail hx)

def removeEpsilonRules
    (g : ContextFreeGrammar T) [DecidableEq T] [DecidableEq g.NT] :
    Finset (ContextFreeRule T g.NT) :=
  let expanded : Finset (ContextFreeRule T g.NT) :=
    g.rules.biUnion fun r =>
      (nullableVariants g r.output).image fun rhs =>
        ({ input := r.input, output := rhs } : ContextFreeRule T g.NT)
  let nonempty := expanded.filter fun r => r.output ≠ []
  let emptyRule : ContextFreeRule T g.NT :=
    { input := g.initial, output := [] }
  nonempty ∪ if g.initial ∈ nullableSet g then {emptyRule} else ∅

def removeEpsilon
    (g : ContextFreeGrammar T) [DecidableEq T] [DecidableEq g.NT] :
    ContextFreeGrammar T :=
  { NT := g.NT
    initial := g.initial
    rules := removeEpsilonRules g }

@[grind =, simp] private theorem removeEpsilon_initial (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] :
    (removeEpsilon g).initial = g.initial := rfl

@[grind] theorem mem_removeEpsilon_rules
    (g : ContextFreeGrammar T) [DecidableEq T] [DecidableEq g.NT]
    (r : ContextFreeRule T g.NT) :
    r ∈ removeEpsilonRules g ↔
      ((∃ oldRule ∈ g.rules, ∃ rhs ∈ nullableVariants g oldRule.output,
          ({ input := oldRule.input, output := rhs } : ContextFreeRule T g.NT) = r) ∧
        r.output ≠ []) ∨
      (Nullable g g.initial ∧
        r = ({ input := g.initial, output := [] } : ContextFreeRule T g.NT)) := by
  classical
  change r ∈ removeEpsilonRules g ↔ _
  change r ∈
    ((g.rules.biUnion fun oldRule =>
      (nullableVariants g oldRule.output).image fun rhs =>
        ({ input := oldRule.input, output := rhs } : ContextFreeRule T g.NT)).filter
      fun rule => rule.output ≠ []) ∪
      (if g.initial ∈ nullableSet g then
        {({ input := g.initial, output := [] } : ContextFreeRule T g.NT)} else ∅) ↔ _
  rw [Finset.mem_union, Finset.mem_filter, Finset.mem_biUnion]
  by_cases hnullable : Nullable g g.initial
  · simp [hnullable, (mem_nullableSet_iff g).mpr hnullable, Finset.mem_image]
  · have hnotmem : g.initial ∉ nullableSet g := by
      simpa [mem_nullableSet_iff g] using hnullable
    simp [hnullable, hnotmem, Finset.mem_image]

@[grind] theorem removeEpsilon_no_noninitial_empty (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] :
    ∀ r ∈ (removeEpsilon g).rules,
      r.output = [] → r.input = (removeEpsilon g).initial := by
  intro r hr hout
  change ContextFreeRule T g.NT at r
  change r ∈ removeEpsilonRules g at hr
  rw [mem_removeEpsilon_rules] at hr
  rcases hr with ⟨_, hne⟩ | ⟨_, rfl⟩
  · exact (hne hout).elim
  · rfl

@[grind] theorem removeEpsilon_initial_not_output (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    (h : ∀ r ∈ g.rules,
      Symbol.nonterminal g.initial ∉ r.output) :
    ∀ r ∈ (removeEpsilon g).rules,
      Symbol.nonterminal (removeEpsilon g).initial ∉ r.output := by
  intro r hr hmem
  change ContextFreeRule T g.NT at r
  change r ∈ removeEpsilonRules g at hr
  rw [mem_removeEpsilon_rules] at hr
  rcases hr with ⟨⟨oldRule, hold, rhs, hvariant, rfl⟩, _⟩ | ⟨_, rfl⟩
  · exact h oldRule hold (mem_of_mem_nullableVariants g hvariant hmem)
  · exact List.not_mem_nil hmem

@[grind] theorem removeEpsilon_reverse_step (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    {u v : List (Symbol T g.NT)}
    (h : (removeEpsilon g).Produces u v) : g.Derives u v := by
  change ∃ r : ContextFreeRule T g.NT,
    r ∈ removeEpsilonRules g ∧ r.Rewrites u v at h
  rcases h with ⟨r, hr, hrewrite⟩
  rw [mem_removeEpsilon_rules] at hr
  rcases hr with ⟨⟨oldRule, hold, rhs, hvariant, hrule⟩, _⟩ | ⟨hnullable, hrule⟩
  · subst r
    obtain ⟨p, q, rfl, rfl⟩ := hrewrite.exists_parts
    have hfirst : g.Produces
        (p ++ [Symbol.nonterminal oldRule.input] ++ q)
        (p ++ oldRule.output ++ q) :=
      ⟨oldRule, hold, ContextFreeRule.rewrites_of_exists_parts oldRule p q⟩
    exact hfirst.single.trans
      ((derives_of_mem_nullableVariants g hvariant).append_left p |>.append_right q)
  · subst r
    obtain ⟨p, q, rfl, rfl⟩ := hrewrite.exists_parts
    simpa using (hnullable.append_left p).append_right q

```

## ε 除去の逆向きシミュレーション

削除済み規則の一歩を元文法の複数歩へ展開し、nullable 記号の消去を意味論的に正当化する。反射推移閉包へ持ち上げて、変換後の語が元言語にも属することを示す。

```lean
@[grind] theorem removeEpsilon_language_reverse (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] :
    (removeEpsilon g).language ≤ g.language := by
  intro w hw
  have h := ContextFreeGrammar.derives_lift_of_produces
    (g₁ := removeEpsilon g) (g₂ := g) (mapSym := id)
    (fun {u v} hstep => by
      have hr := removeEpsilon_reverse_step g (u := u) (v := v) hstep
      have hu : List.map id u = u := List.map_id u
      have hv : List.map id v = v := List.map_id v
      exact hu.symm ▸ hv.symm ▸ hr) hw
  have hroot :
      List.map (id : Symbol T g.NT → Symbol T g.NT)
        [(Symbol.nonterminal (removeEpsilon g).initial : Symbol T g.NT)] =
      [(Symbol.nonterminal g.initial : Symbol T g.NT)] := by
    simp [removeEpsilon_initial]
  have hyield :
      List.map (id : Symbol T g.NT → Symbol T g.NT)
        (List.map (Symbol.terminal : T → Symbol T g.NT) w) =
      List.map (Symbol.terminal : T → Symbol T g.NT) w := by
    exact List.map_id _
  change g.Derives [Symbol.nonterminal g.initial] (List.map Symbol.terminal w)
  exact hroot ▸ hyield ▸ h


def ErasesNullable (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    (u v : List (Symbol T g.NT)) : Prop :=
  v ∈ nullableVariants g u

@[grind] theorem removeEpsilon_produces_variant (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    {r : ContextFreeRule T g.NT} (hr : r ∈ g.rules)
    {rhs' : List (Symbol T g.NT)}
    (hvariant : rhs' ∈ nullableVariants g r.output)
    (hne : rhs' ≠ []) (p q : List (Symbol T g.NT)) :
    (removeEpsilon g).Produces
      (p ++ [Symbol.nonterminal r.input] ++ q)
      (p ++ rhs' ++ q) := by
  refine ⟨{ input := r.input, output := rhs' }, ?_,
    ContextFreeRule.rewrites_of_exists_parts _ p q⟩
  change ({ input := r.input, output := rhs' } : ContextFreeRule T g.NT) ∈
    removeEpsilonRules g
  rw [mem_removeEpsilon_rules]
  left
  exact ⟨⟨r, hr, rhs', hvariant, rfl⟩, hne⟩

@[grind] theorem removeEpsilon_start_empty (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    (h : Nullable g g.initial) :
    (removeEpsilon g).Derives [Symbol.nonterminal g.initial] [] := by
  apply ContextFreeGrammar.Produces.single
  refine ⟨{ input := g.initial, output := [] }, ?_,
    ContextFreeRule.Rewrites.input_output⟩
  change ({ input := g.initial, output := [] } : ContextFreeRule T g.NT) ∈
    removeEpsilonRules g
  rw [mem_removeEpsilon_rules]
  exact Or.inr ⟨h, rfl⟩
@[grind] theorem removeEpsilon_simulation (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    {u s : List (Symbol T g.NT)} (h : g.Derives u s) :
    ∃ u' ∈ nullableVariants g u, (removeEpsilon g).Derives u' s := by
  classical
  induction h using Relation.ReflTransGen.head_induction_on with
  | refl =>
      exact ⟨s, self_mem_nullableVariants g s,
        ContextFreeGrammar.Derives.refl (g := removeEpsilon g) s⟩
  | @head u v hstep hrest ih =>
      rcases hstep with ⟨r, hr, hrewrite⟩
      obtain ⟨p, q, hu, hv⟩ := hrewrite.exists_parts
      subst u
      subst v
      obtain ⟨v', hvvariant, hvderives⟩ := ih
      have hvvariant' :
          v' ∈ nullableVariants g (p ++ (r.output ++ q)) := by
        simpa [List.append_assoc] using hvvariant
      obtain ⟨p', hp', rest, hrest', rfl⟩ :=
        (mem_nullableVariants_append g).mp hvvariant'
      obtain ⟨rhs', hrhs', q', hq', rfl⟩ :=
        (mem_nullableVariants_append g).mp hrest'
      by_cases hne : rhs' = []
      · subst rhs'
        have hnullable : Nullable g r.input := by
          have hfirst : g.Produces [Symbol.nonterminal r.input] r.output :=
            ⟨r, hr, ContextFreeRule.Rewrites.input_output⟩
          exact hfirst.single.trans (derives_of_mem_nullableVariants g hrhs')
        have hempty :
            ([] : List (Symbol T g.NT)) ∈
              nullableVariants g [Symbol.nonterminal r.input] := by
          simp [nullableVariants, (mem_nullableSet_iff g).mpr hnullable]
        have hmiddle :
            q' ∈ nullableVariants g
              ([Symbol.nonterminal r.input] ++ q) := by
          apply (mem_nullableVariants_append g).mpr
          exact ⟨[], hempty, q', hq', by simp⟩
        have hsource' :
            p' ++ q' ∈ nullableVariants g
              (p ++ ([Symbol.nonterminal r.input] ++ q)) :=
          (mem_nullableVariants_append g).mpr
            ⟨p', hp', q', hmiddle, rfl⟩
        have hsource :
            p' ++ q' ∈ nullableVariants g
              (p ++ [Symbol.nonterminal r.input] ++ q) := by
          simpa [List.append_assoc] using hsource'
        exact ⟨p' ++ q', hsource, by
          simpa [List.append_assoc] using hvderives⟩
      · have hmiddle :
            [Symbol.nonterminal r.input] ++ q' ∈ nullableVariants g
              ([Symbol.nonterminal r.input] ++ q) := by
          apply (mem_nullableVariants_append g).mpr
          exact ⟨[Symbol.nonterminal r.input],
            self_mem_nullableVariants g [Symbol.nonterminal r.input],
            q', hq', rfl⟩
        have hsource' :
            p' ++ ([Symbol.nonterminal r.input] ++ q') ∈
              nullableVariants g
                (p ++ ([Symbol.nonterminal r.input] ++ q)) :=
          (mem_nullableVariants_append g).mpr
            ⟨p', hp', [Symbol.nonterminal r.input] ++ q',
              hmiddle, rfl⟩
        have hsource :
            p' ++ [Symbol.nonterminal r.input] ++ q' ∈
              nullableVariants g
                (p ++ [Symbol.nonterminal r.input] ++ q) := by
          simpa [List.append_assoc] using hsource'
        have hproduces :=
          removeEpsilon_produces_variant g hr hrhs' hne p' q'
        exact ⟨p' ++ [Symbol.nonterminal r.input] ++ q', hsource,
          hproduces.single.trans (by
            simpa [List.append_assoc] using hvderives)⟩

```

## ε 除去の順向きシミュレーション

元文法の導出から nullable 記号を消去した対応導出を構成し、非空語について変換後文法へ移送する。空語の場合は fresh-start 規則で別処理し、最終的な言語等式を得る。

```lean
@[grind] theorem derives_from_empty_eq (g : ContextFreeGrammar T)
    {v : List (Symbol T g.NT)} (h : g.Derives [] v) : v = [] := by
  rcases h.eq_or_head with heq | ⟨w, hstep, _⟩
  · exact heq.symm
  · rcases hstep with ⟨r, _, hrewrite⟩
    have hmem := hrewrite.nonterminal_input_mem
    simp at hmem

@[grind] theorem removeEpsilon_language_forward (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] :
    g.language ≤ (removeEpsilon g).language := by
  intro w hw
  by_cases hwempty : w = []
  · subst w
    exact removeEpsilon_start_empty g hw
  · obtain ⟨u', hu', hderives⟩ := removeEpsilon_simulation g hw
    have hcases :
        u' = [Symbol.nonterminal g.initial] ∨ u' = [] := by
      simp only [nullableVariants] at hu'
      split at hu'
      · simpa using hu'
      · exact Or.inl (by simpa using hu')
    rcases hcases with rfl | rfl
    · exact hderives
    · have hterminalEmpty := derives_from_empty_eq (removeEpsilon g) hderives
      have hlength := congrArg List.length hterminalEmpty
      simp only [List.length_map, List.length_nil] at hlength
      have hw_nil : w = [] := List.eq_nil_of_length_eq_zero hlength
      exact (hwempty hw_nil).elim

@[grind] theorem removeEpsilon_language (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] :
    (removeEpsilon g).language = g.language :=
  le_antisymm (removeEpsilon_language_reverse g)
    (removeEpsilon_language_forward g)

/-! ## Elimination of unit productions -/

def IsUnitRule {T N : Type*} (r : ContextFreeRule T N) : Prop :=
  ∃ B, r.output = [Symbol.nonterminal B]

def isUnitRule (r : ContextFreeRule T N) : Bool :=
  match r.output with
  | [.nonterminal _] => true
  | _ => false

@[grind] theorem isUnitRule_eq_true (r : ContextFreeRule T N) :
    isUnitRule r = true ↔ IsUnitRule r := by
  rcases r with ⟨input, output⟩
  cases output with
  | nil => simp [isUnitRule, IsUnitRule]
  | cons x xs =>
      cases xs with
      | nil =>
          cases x <;> simp [isUnitRule, IsUnitRule]
      | cons y ys => simp [isUnitRule, IsUnitRule]


def UnitStep (g : ContextFreeGrammar T) (A B : g.NT) : Prop :=
  ({ input := A, output := [Symbol.nonterminal B] } :
    ContextFreeRule T g.NT) ∈ g.rules

abbrev UnitReach (g : ContextFreeGrammar T) :=
  Relation.ReflTransGen (UnitStep g)

def unitRuleEscapes [DecidableEq N] (S : Finset N)
    (r : ContextFreeRule T N) : Bool :=
  match r.output with
  | [.nonterminal B] => decide (r.input ∈ S) && decide (B ∉ S)
  | _ => false

def unitClosed (g : ContextFreeGrammar T) [DecidableEq T]
    [DecidableEq g.NT] (S : Finset g.NT) : Bool :=
  decide (g.rules.filter (fun r => unitRuleEscapes S r = true) = ∅)

/-- The executable reflexive-transitive unit reachability set from `A`. -/
def unitReachSet (g : ContextFreeGrammar T) [DecidableEq T]
    [DecidableEq g.NT] (A : g.NT) : Finset g.NT :=
  let support := activeNonterminals g
  let closed := support.powerset.filter fun S =>
    A ∈ S ∧ unitClosed g S = true
  support.filter fun B => closed.filter (fun S => B ∉ S) = ∅

@[grind] theorem unitClosed_eq_true (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] {S : Finset g.NT} :
    unitClosed g S = true ↔
      ∀ {B C}, B ∈ S → UnitStep g B C → C ∈ S := by
  simp only [unitClosed, decide_eq_true_eq, Finset.filter_eq_empty_iff]
  constructor
  · intro h B C hB hstep
    by_contra hC
    exact h hstep (by simp [unitRuleEscapes, hB, hC])
  · intro h r hr hescapes
    rcases r with ⟨B, output⟩
    simp only [unitRuleEscapes] at hescapes
    split at hescapes <;> try contradiction
    next C _ =>
      simp only [Bool.and_eq_true, decide_eq_true_eq] at hescapes
      exact hescapes.2 (h hescapes.1 hr)
@[grind] theorem unitReach_mem_of_closed (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] {S : Finset g.NT} {A B : g.NT}
    (hclosed : unitClosed g S = true) (hA : A ∈ S)
    (hreach : UnitReach g A B) : B ∈ S := by
  induction hreach with
  | refl => exact hA
  | tail h hstep ih =>
      exact (unitClosed_eq_true g).mp hclosed ih hstep


/-- Computed unit reachability agrees with reflexive-transitive closure on the
finite grammar support. -/
@[grind] theorem mem_unitReachSet_iff (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] {A B : g.NT}
    (hA : A ∈ activeNonterminals g) :
    B ∈ unitReachSet g A ↔ UnitReach g A B := by
  classical
  let semantic := (activeNonterminals g).filter fun C => UnitReach g A C
  have hsemantic_closed : unitClosed g semantic = true := by
    rw [unitClosed_eq_true]
    intro C D hC hstep
    apply Finset.mem_filter.mpr
    refine ⟨rule_rhs_mem_activeNonterminals g hstep (by simp), ?_⟩
    exact Relation.ReflTransGen.tail (Finset.mem_filter.mp hC).2 hstep
  have hsemantic_start : A ∈ semantic :=
    Finset.mem_filter.mpr ⟨hA, Relation.ReflTransGen.refl⟩
  constructor
  · intro hB
    simp only [unitReachSet, Finset.mem_filter] at hB
    have hsemPower : semantic ∈ (activeNonterminals g).powerset :=
      Finset.mem_powerset.mpr fun C hC => (Finset.mem_filter.mp hC).1
    have hsemClosed :
        semantic ∈ (activeNonterminals g).powerset.filter
          (fun S => A ∈ S ∧ unitClosed g S = true) :=
      Finset.mem_filter.mpr
        ⟨hsemPower, hsemantic_start, hsemantic_closed⟩
    by_contra hreach
    have hmissing : semantic ∈
        ((activeNonterminals g).powerset.filter
          (fun S => A ∈ S ∧ unitClosed g S = true)).filter
          (fun S => B ∉ S) :=
      Finset.mem_filter.mpr
        ⟨hsemClosed, by simpa [semantic, hreach]⟩
    simpa [hmissing] using congrArg (fun s => semantic ∉ s) hB.2
  · intro hreach
    have hBactive : B ∈ activeNonterminals g := by
      rcases hreach.cases_tail with rfl | ⟨C, _, hstep⟩
      · exact hA
      · exact rule_rhs_mem_activeNonterminals g hstep (by simp)
    refine Finset.mem_filter.mpr ⟨hBactive, ?_⟩
    apply Finset.filter_eq_empty_iff.mpr
    intro S hS hmissing
    rcases Finset.mem_filter.mp hS with ⟨_, hstart, hclosed⟩
    exact hmissing (unitReach_mem_of_closed g hclosed hstart hreach)

```

## unit 到達関係と unit 規則除去

非終端記号一個だけを右辺に持つ規則の反射推移閉包を `unitReach` として計算し、到達先の非 unit 規則を元へ引き上げる。出力文法から unit 規則が消えることを構造的に保証する。

```lean
abbrev removeUnit
    (g : ContextFreeGrammar T) [DecidableEq T] [DecidableEq g.NT] :
    ContextFreeGrammar T :=
  { NT := g.NT
    initial := g.initial
    rules :=
      (((activeNonterminals g).product (activeNonterminals g)).filter
          fun p => p.2 ∈ unitReachSet g p.1).biUnion fun p =>
        (g.rules.filter fun r : ContextFreeRule T g.NT =>
          r.input = p.2 ∧ isUnitRule r = false).image
          fun r => ({ input := p.1, output := r.output } :
            ContextFreeRule T g.NT) }
@[grind] theorem mem_removeUnit_rules_iff (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    (r : ContextFreeRule T g.NT) :
    r ∈ (removeUnit g).rules ↔
      ∃ p : g.NT × g.NT,
        p ∈ (activeNonterminals g).product (activeNonterminals g) ∧
        UnitReach g p.1 p.2 ∧
        ∃ oldRule ∈ g.rules,
          oldRule.input = p.2 ∧ ¬IsUnitRule oldRule ∧
          ({ input := p.1, output := oldRule.output } :
            ContextFreeRule T g.NT) = r := by
  classical
  constructor
  · intro hr
    obtain ⟨p, hp, hr⟩ := Finset.mem_biUnion.mp hr
    obtain ⟨hpactive, hreachMem⟩ := Finset.mem_filter.mp hp
    have hreach : UnitReach g p.1 p.2 :=
      (mem_unitReachSet_iff g (Finset.mem_product.mp hpactive).1).mp hreachMem
    obtain ⟨oldRule, hold, heq⟩ := Finset.mem_image.mp hr
    obtain ⟨holdRule, hinput, hnonunitBool⟩ := Finset.mem_filter.mp hold
    have hnonunit : ¬ IsUnitRule oldRule := by
      simpa [← isUnitRule_eq_true] using hnonunitBool
    exact ⟨p, hpactive, hreach, oldRule, holdRule, hinput, hnonunit, heq⟩
  · rintro ⟨p, hpactive, hreach, oldRule, hold, hinput, hnonunit, rfl⟩
    apply Finset.mem_biUnion.mpr
    have hreachMem : p.2 ∈ unitReachSet g p.1 :=
      (mem_unitReachSet_iff g (Finset.mem_product.mp hpactive).1).mpr hreach
    exact ⟨p, Finset.mem_filter.mpr ⟨hpactive, hreachMem⟩,
      Finset.mem_image.mpr
        ⟨oldRule, Finset.mem_filter.mpr
          ⟨hold, hinput, by simpa [← isUnitRule_eq_true] using hnonunit⟩, rfl⟩⟩
@[grind] theorem removeUnit_no_unit (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] :
    ∀ r ∈ (removeUnit g).rules, ¬IsUnitRule r := by
  change ∀ r : ContextFreeRule T g.NT,
    r ∈ (removeUnit g).rules → ¬IsUnitRule r
  classical
  intro r hr
  obtain ⟨p, _, _, oldRule, _, _, hnonunit, rfl⟩ :=
    (mem_removeUnit_rules_iff g r).mp hr
  simpa [IsUnitRule] using hnonunit
@[grind] theorem removeUnit_initial_not_output (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    (h : ∀ r ∈ g.rules,
      Symbol.nonterminal g.initial ∉ r.output) :
    ∀ r ∈ (removeUnit g).rules,
      Symbol.nonterminal (removeUnit g).initial ∉ r.output := by
  classical
  intro r hr
  obtain ⟨_, _, _, oldRule, hold, _, _, rfl⟩ :=
    (mem_removeUnit_rules_iff g r).mp hr
  exact h oldRule hold

@[grind] theorem removeUnit_rule_mem (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    {A B : g.NT} {r : ContextFreeRule T g.NT}
    (hA : A ∈ activeNonterminals g) (hB : B ∈ activeNonterminals g)
    (hreach : UnitReach g A B) (hr : r ∈ g.rules)
    (hinput : r.input = B) (hnonunit : ¬ IsUnitRule r) :
    ({ input := A, output := r.output } : ContextFreeRule T g.NT) ∈
      (removeUnit g).rules := by
  classical
  apply Finset.mem_biUnion.mpr
  have hpactive : (A, B) ∈
      (activeNonterminals g).product (activeNonterminals g) :=
    Finset.mem_product.mpr ⟨hA, hB⟩
  have hreachMem : B ∈ unitReachSet g A :=
    (mem_unitReachSet_iff g hA).mpr hreach
  refine ⟨(A, B), Finset.mem_filter.mpr ⟨hpactive, hreachMem⟩, ?_⟩
  · apply Finset.mem_image.mpr
    exact ⟨r, Finset.mem_filter.mpr
      ⟨hr, hinput, by simpa [← isUnitRule_eq_true] using hnonunit⟩, rfl⟩

def UnitSymbolLift (g : ContextFreeGrammar T) [DecidableEq g.NT] :
    Symbol T g.NT → Symbol T g.NT → Prop
  | .terminal a, .terminal b => a = b
  | .nonterminal A, .nonterminal B =>
      A ∈ activeNonterminals g ∧ UnitReach g A B
  | _, _ => False

def UnitLift (g : ContextFreeGrammar T) [DecidableEq g.NT]
    (u v : List (Symbol T g.NT)) : Prop :=
  List.Forall₂ (UnitSymbolLift g) u v

@[grind] theorem unitLift_refl_of_active (g : ContextFreeGrammar T)
    [DecidableEq g.NT]
    (xs : List (Symbol T g.NT))
    (hactive : ∀ A, Symbol.nonterminal A ∈ xs →
      A ∈ activeNonterminals g) :
    UnitLift g xs xs := by
  induction xs with
  | nil => exact List.Forall₂.nil
  | cons x xs ih =>
      apply List.Forall₂.cons
      · cases x with
        | terminal a => rfl
        | nonterminal A =>
            exact ⟨hactive A (by simp), Relation.ReflTransGen.refl⟩
      · apply ih
        intro A hA
        exact hactive A (List.mem_cons_of_mem x hA)

@[grind] theorem unitLift_rule_output (g : ContextFreeGrammar T)
    [DecidableEq g.NT]
    {r : ContextFreeRule T g.NT} (hr : r ∈ g.rules) :
    UnitLift g r.output r.output :=
  unitLift_refl_of_active g r.output fun A hA =>
    rule_rhs_mem_activeNonterminals g hr hA

```

## unit 除去の順向き持ち上げ

元の一歩を unit 到達部分と実規則部分へ分解し、除去後文法の導出へ持ち上げる。局所シミュレーションを導出列全体へ拡張して、元言語から変換後言語への包含を得る。

```lean
@[grind] theorem unitLift_parts (g : ContextFreeGrammar T)
    [DecidableEq g.NT]
    {u' p q : List (Symbol T g.NT)} {x : Symbol T g.NT}
    (h : UnitLift g u' (p ++ x :: q)) :
    ∃ p' x' q', u' = p' ++ x' :: q' ∧
      UnitLift g p' p ∧ UnitSymbolLift g x' x ∧ UnitLift g q' q := by
  induction p generalizing u' with
  | nil =>
      cases h with
      | cons hx hq =>
          exact ⟨[], _, _, rfl, List.Forall₂.nil, hx, hq⟩
  | cons y p ih =>
      cases h with
      | cons hy htail =>
          obtain ⟨p', x', q', rfl, hp', hx', hq'⟩ := ih htail
          exact ⟨_ :: p', x', q', rfl,
            List.Forall₂.cons hy hp', hx', hq'⟩

@[grind] theorem removeUnit_lift_step (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    {u v u' : List (Symbol T g.NT)} (hstep : g.Produces u v)
    (hlift : UnitLift g u' u) :
    ∃ v', (removeUnit g).Derives u' v' ∧ UnitLift g v' v := by
  classical
  rcases hstep with ⟨r, hr, hrewrite⟩
  obtain ⟨p, q, rfl, rfl⟩ := hrewrite.exists_parts
  have hlift' : UnitLift g u'
      (p ++ (Symbol.nonterminal r.input :: q)) := by
    simpa [List.append_assoc] using hlift
  obtain ⟨p', x', q', rfl, hp', hx', hq'⟩ :=
    unitLift_parts g hlift'
  cases x' with
  | terminal a => simp [UnitSymbolLift] at hx'
  | nonterminal A =>
      rcases hx' with ⟨hA, hreach⟩
      by_cases hunit : IsUnitRule r
      · obtain ⟨B, houtput⟩ := hunit
        have hunitStep : UnitStep g r.input B := by
          unfold UnitStep
          have heq :
              ({ input := r.input,
                 output := [Symbol.nonterminal B] } :
                ContextFreeRule T g.NT) = r := by
            apply ContextFreeRule.ext
            · rfl
            · exact houtput.symm
          rw [heq]
          exact hr
        have hcenter : UnitSymbolLift g
            (Symbol.nonterminal A) (Symbol.nonterminal B) :=
          ⟨hA, hreach.tail hunitStep⟩
        refine ⟨p' ++ Symbol.nonterminal A :: q',
          ContextFreeGrammar.Derives.refl _, ?_⟩
        simpa only [UnitLift, houtput, List.append_assoc,
          List.singleton_append] using
          List.rel_append hp' (List.Forall₂.cons hcenter hq')
      · have hB := rule_input_mem_activeNonterminals g hr
        have hrule := removeUnit_rule_mem g hA hB hreach hr rfl hunit
        have hrewrite' :
            ({ input := A, output := r.output } :
              ContextFreeRule T g.NT).Rewrites
              (p' ++ Symbol.nonterminal A :: q')
              (p' ++ r.output ++ q') := by
          simpa only [List.append_assoc, List.singleton_append] using
            ContextFreeRule.rewrites_of_exists_parts
              ({ input := A, output := r.output } :
                ContextFreeRule T g.NT) p' q'
        have hproduces : (removeUnit g).Produces
            (p' ++ Symbol.nonterminal A :: q')
            (p' ++ r.output ++ q') :=
          ⟨{ input := A, output := r.output }, hrule, hrewrite'⟩
        refine ⟨p' ++ r.output ++ q', hproduces.single, ?_⟩
        · simpa only [UnitLift, List.append_assoc] using
            List.rel_append hp'
              (List.rel_append (unitLift_rule_output g hr) hq')


@[grind] theorem removeUnit_simulation (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    {u v u' : List (Symbol T g.NT)} (h : g.Derives u v)
    (hlift : UnitLift g u' u) :
    ∃ v', (removeUnit g).Derives u' v' ∧ UnitLift g v' v := by
  induction h using Relation.ReflTransGen.head_induction_on generalizing u' with
  | refl =>
      exact ⟨u', ContextFreeGrammar.Derives.refl _, hlift⟩
  | head hstep hrest ih =>
      obtain ⟨middle, hmiddle, hliftMiddle⟩ :=
        removeUnit_lift_step g hstep hlift
      obtain ⟨v', hv', hlift'⟩ := ih hliftMiddle
      exact ⟨v', hmiddle.trans hv', hlift'⟩

@[grind] theorem unitLift_terminalSymbols_eq (g : ContextFreeGrammar T)
    [DecidableEq g.NT]
    {u : List (Symbol T g.NT)} {w : List T}
    (h : UnitLift g u (terminalSymbols w)) :
    u = terminalSymbols w := by
  induction w generalizing u with
  | nil =>
      cases h
      rfl
  | cons a w ih =>
      cases h with
      | cons hx htail =>
          rename_i x xs
          cases x with
          | terminal b =>
              change b = a at hx
              subst b
              simp only [terminalSymbols, List.map_cons]
              exact congrArg (Symbol.terminal a :: ·) (ih htail)
          | nonterminal A => simp [UnitSymbolLift] at hx

@[grind] theorem removeUnit_language_forward (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] :
    g.language ≤ (removeUnit g).language := by
  intro w hw
  have hstart : UnitLift g
      [Symbol.nonterminal g.initial] [Symbol.nonterminal g.initial] :=
    List.Forall₂.cons
      ⟨initial_mem_activeNonterminals g, Relation.ReflTransGen.refl⟩
      List.Forall₂.nil
  obtain ⟨v', hderives, hlift⟩ := removeUnit_simulation g hw hstart
  have heq := unitLift_terminalSymbols_eq g hlift
  subst v'
  exact hderives

```

## unit 除去の逆向き展開

`unitReach` の各辺と引き上げた規則を元文法の導出へ戻す。除去後の一歩を元の複数歩で模倣し、逆包含と最終的な言語保存を閉じる。

```lean
@[grind] theorem derives_unitReach (g : ContextFreeGrammar T) {A B : g.NT}
    (h : UnitReach g A B) :
    g.Derives [Symbol.nonterminal A] [Symbol.nonterminal B] := by
  induction h with
  | refl => exact ContextFreeGrammar.Derives.refl _
  | tail hreach hstep ih =>
      exact ih.trans_produces
        ⟨{ input := _, output := [Symbol.nonterminal _] }, hstep,
          ContextFreeRule.Rewrites.input_output⟩

@[grind] theorem removeUnit_reverse_step (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    {u v : List (Symbol T g.NT)}
    (h : (removeUnit g).Produces u v) : g.Derives u v := by
  classical
  change ∃ r : ContextFreeRule T g.NT,
    r ∈ (removeUnit g).rules ∧ r.Rewrites u v at h
  rcases h with ⟨r, hr, hrewrite⟩
  obtain ⟨⟨A, B⟩, _, hreach, oldRule, hold, hinput, _, rfl⟩ :=
    (mem_removeUnit_rules_iff g r).mp hr
  obtain ⟨p, q, rfl, rfl⟩ := hrewrite.exists_parts
  have hchain := (derives_unitReach g hreach).append_left p |>.append_right q
  have hlast : g.Produces
      (p ++ [Symbol.nonterminal B] ++ q)
      (p ++ oldRule.output ++ q) :=
    ⟨oldRule, hold, by
      simpa [hinput] using
        ContextFreeRule.rewrites_of_exists_parts oldRule p q⟩
  exact hchain.trans_produces hlast
@[grind] theorem removeUnit_language_reverse (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] :
    (removeUnit g).language ≤ g.language := by
  intro w hw
  have h := ContextFreeGrammar.derives_lift_of_produces
    (g₁ := removeUnit g) (g₂ := g) (mapSym := id)
    (fun {u v} hstep => by
      have hu : List.map id u = u := List.map_id u
      have hv : List.map id v = v := List.map_id v
      exact hu.symm ▸ hv.symm ▸ removeUnit_reverse_step g hstep) hw
  change g.Derives [Symbol.nonterminal g.initial] (List.map Symbol.terminal w)
  have hroot :
      List.map (id : Symbol T g.NT → Symbol T g.NT)
        [Symbol.nonterminal (removeUnit g).initial] =
      [Symbol.nonterminal g.initial] := by
    simp [removeUnit]
  have hyield :
      List.map (id : Symbol T g.NT → Symbol T g.NT)
        (List.map (Symbol.terminal : T → Symbol T g.NT) w) =
      List.map (Symbol.terminal : T → Symbol T g.NT) w :=
    List.map_id _
  exact hroot ▸ hyield ▸ h
@[grind] theorem removeUnit_language (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] :
    (removeUnit g).language = g.language :=
  le_antisymm (removeUnit_language_reverse g)
    (removeUnit_language_forward g)

end ContextFreeGrammar

namespace ContextFreeGrammar

/-! ## Isolation of terminals in long right-hand sides -/


/-! Terminal isolation for small terminal types.

Helper nonterminals store terminal values directly. Since
`ContextFreeGrammar.NT` lives in `Type`, the complete conversion using this
construction is available when the terminal alphabet also lives in `Type`. -/

@[grind cases] inductive IsolateNT (T N : Type*) where
  | old (A : N)
  | terminal (a : T)
deriving DecidableEq, Repr

def IsolateNT.orderKey :
    IsolateNT T N → N ⊕ₗ T
  | .old A => Sum.inlₗ A
  | .terminal a => Sum.inrₗ a

instance [LinearOrder T] [LinearOrder N] : LinearOrder (IsolateNT T N) :=
  LinearOrder.lift' IsolateNT.orderKey (by
    intro x y h
    cases x <;> cases y <;> simp_all [IsolateNT.orderKey])

def isolateOutput {T N : Type*} :
    List (Symbol T N) → List (Symbol T (IsolateNT T N))
  | [] => []
  | .terminal a :: xs =>
      .nonterminal (.terminal a) :: isolateOutput xs
  | .nonterminal A :: xs =>
      .nonterminal (.old A) :: isolateOutput xs

def symbolTerminal {T N : Type*} : Symbol T N → Option T
  | .terminal a => some a
  | .nonterminal _ => none

def isolatedRule (r : ContextFreeRule T N) :
    ContextFreeRule T (IsolateNT T N) :=
  if 2 ≤ r.output.length then
    { input := .old r.input, output := isolateOutput r.output }
  else
    ContextFreeRule.mapNonterminal IsolateNT.old r

def terminalIsolationRule (a : T) :
    ContextFreeRule T (IsolateNT T N) :=
  { input := .terminal a, output := [.terminal a] }

def isolationRules
    (g : ContextFreeGrammar T) [DecidableEq T] [DecidableEq g.NT] :
    Finset (ContextFreeRule T (IsolateNT T g.NT)) :=
  g.rules.image isolatedRule ∪
    g.rules.biUnion fun r =>
      if 2 ≤ r.output.length then
        (r.output.filterMap symbolTerminal).toFinset.image terminalIsolationRule
      else ∅

abbrev isolateTerminals
    (g : ContextFreeGrammar T) [DecidableEq T] [DecidableEq g.NT] :
    ContextFreeGrammar T :=
  { NT := IsolateNT T g.NT
    initial := .old g.initial
    rules := isolationRules g }

```

## 終端記号分離規則の特徴付け

長い右辺に現れる終端記号を専用非終端記号へ置換した規則集合を外延的に特徴付ける。元規則と新しい terminal 規則の双方が確実に含まれることを、後続シミュレーション用の API として示す。

```lean
@[grind] theorem mem_isolateTerminals_rules_iff
    (g : ContextFreeGrammar T) [DecidableEq T] [DecidableEq g.NT]
    (r : ContextFreeRule T (IsolateNT T g.NT)) :
    r ∈ (isolateTerminals g).rules ↔
      (∃ oldRule ∈ g.rules, isolatedRule oldRule = r) ∨
      ∃ oldRule ∈ g.rules, 2 ≤ oldRule.output.length ∧
        ∃ a ∈ (oldRule.output.filterMap symbolTerminal).toFinset,
          terminalIsolationRule a = r := by
  classical
  simp only [isolateTerminals, isolationRules, Finset.mem_union,
    Finset.mem_image, Finset.mem_biUnion]
  constructor
  · rintro (⟨oldRule, hold, rfl⟩ | ⟨oldRule, hold, hgenerated⟩)
    · exact Or.inl ⟨oldRule, hold, rfl⟩
    · right
      by_cases hlong : 2 ≤ oldRule.output.length
      · simp only [hlong, if_pos, Finset.mem_image] at hgenerated
        obtain ⟨a, ha, rfl⟩ := hgenerated
        exact ⟨oldRule, hold, hlong, a, ha, rfl⟩
      · simp [hlong] at hgenerated
  · rintro (⟨oldRule, hold, rfl⟩ |
      ⟨oldRule, hold, hlong, a, ha, rfl⟩)
    · exact Or.inl ⟨oldRule, hold, rfl⟩
    · right
      refine ⟨oldRule, hold, ?_⟩
      simp only [hlong, if_pos, Finset.mem_image]
      exact ⟨a, ha, rfl⟩

@[grind] theorem terminal_mem_filterMap {N : Type*}
    {a : T} {xs : List (Symbol T N)} :
    a ∈ xs.filterMap symbolTerminal ↔ Symbol.terminal a ∈ xs := by
  constructor
  · intro h
    obtain ⟨s, hs, hsa⟩ := List.mem_filterMap.mp h
    cases s <;> simp [symbolTerminal] at hsa
    subst hsa
    exact hs
  · intro h
    apply List.mem_filterMap.mpr
    exact ⟨Symbol.terminal a, h, by simp [symbolTerminal]⟩

@[grind] theorem isolate_old_rule_mem (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    {r : ContextFreeRule T g.NT} (hr : r ∈ g.rules)
    (hlong : 2 ≤ r.output.length) :
    ({ input := IsolateNT.old r.input,
       output := isolateOutput r.output } :
      ContextFreeRule T (IsolateNT T g.NT)) ∈
      (isolateTerminals g).rules := by
  apply (mem_isolateTerminals_rules_iff g _).mpr
  left
  exact ⟨r, hr, by simp [isolatedRule, hlong]⟩

@[grind] theorem isolate_terminal_rule_mem (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    {r : ContextFreeRule T g.NT} {a : T}
    (hr : r ∈ g.rules) (hlong : 2 ≤ r.output.length)
    (hterminal : Symbol.terminal a ∈ r.output) :
    (terminalIsolationRule a :
      ContextFreeRule T (IsolateNT T g.NT)) ∈
      (isolateTerminals g).rules := by
  apply (mem_isolateTerminals_rules_iff g _).mpr
  right
  refine ⟨r, hr, hlong, a, ?_, rfl⟩
  exact List.mem_toFinset.mpr (terminal_mem_filterMap.mpr hterminal)

@[grind] theorem isolate_short_rule_mem (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    {r : ContextFreeRule T g.NT} (hr : r ∈ g.rules)
    (hshort : ¬ 2 ≤ r.output.length) :
    ContextFreeRule.mapNonterminal IsolateNT.old r ∈
      (isolateTerminals g).rules := by
  apply (mem_isolateTerminals_rules_iff g _).mpr
  left
  exact ⟨r, hr, by simp [isolatedRule, hshort]⟩

@[grind] theorem derives_isolateOutput (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    {r : ContextFreeRule T g.NT} (hr : r ∈ g.rules)
    (hlong : 2 ≤ r.output.length) :
    (isolateTerminals g).Derives
      (isolateOutput r.output)
      (r.output.map (Symbol.mapNonterminal IsolateNT.old)) := by
  have go : ∀ xs : List (Symbol T g.NT), xs ⊆ r.output →
      (isolateTerminals g).Derives
        (isolateOutput xs)
        (xs.map (Symbol.mapNonterminal IsolateNT.old)) := by
    intro xs hsub
    induction xs with
    | nil => exact ContextFreeGrammar.Derives.refl []
    | cons x xs ih =>
        have htail : xs ⊆ r.output :=
          fun _ hx => hsub (List.mem_cons_of_mem _ hx)
        cases x with
        | terminal a =>
            have hfirst : (isolateTerminals g).Produces
                [Symbol.nonterminal (IsolateNT.terminal a)]
                [Symbol.terminal a] :=
              ⟨_, isolate_terminal_rule_mem g hr hlong (hsub (by simp)),
                ContextFreeRule.Rewrites.input_output⟩
            exact
              (hfirst.append_right (isolateOutput xs)).single.trans
                (by simpa [isolateOutput] using
                  (ih htail).append_left [Symbol.terminal a])
        | nonterminal A =>
            exact (ih htail).append_left
              [Symbol.nonterminal (IsolateNT.old A)]
  exact go r.output fun _ => id

@[grind] theorem isolateTerminals_forward_step
    (g : ContextFreeGrammar T) [DecidableEq T] [DecidableEq g.NT]
    {u v : List (Symbol T g.NT)} (h : g.Produces u v) :
    (isolateTerminals g).Derives
      (u.map (Symbol.mapNonterminal IsolateNT.old))
      (v.map (Symbol.mapNonterminal IsolateNT.old)) := by
  rcases h with ⟨r, hr, hrewrite⟩
  by_cases hlong : 2 ≤ r.output.length
  · obtain ⟨p, q, rfl, rfl⟩ := hrewrite.exists_parts
    let transformed : ContextFreeRule T (IsolateNT T g.NT) :=
      { input := .old r.input, output := isolateOutput r.output }
    have hfirst : (isolateTerminals g).Produces
        (p.map (Symbol.mapNonterminal IsolateNT.old) ++
          [Symbol.nonterminal (IsolateNT.old r.input)] ++
          q.map (Symbol.mapNonterminal IsolateNT.old))
        (p.map (Symbol.mapNonterminal IsolateNT.old) ++
          isolateOutput r.output ++
          q.map (Symbol.mapNonterminal IsolateNT.old)) :=
      ⟨transformed, isolate_old_rule_mem g hr hlong,
        ContextFreeRule.rewrites_of_exists_parts transformed _ _⟩
    simpa only [List.map_append, List.map_cons, List.map_nil,
      Symbol.mapNonterminal_nonterminal, List.append_assoc,
      List.singleton_append] using
      hfirst.single.trans
        (((derives_isolateOutput g hr hlong).append_left
          (p.map (Symbol.mapNonterminal IsolateNT.old))).append_right
            (q.map (Symbol.mapNonterminal IsolateNT.old)))
  · apply ContextFreeGrammar.Produces.single
    exact
      ⟨ContextFreeRule.mapNonterminal IsolateNT.old r,
        isolate_short_rule_mem g hr hlong,
        Mathling.Grammar.ContextFreeRule.Rewrites.mapNonterminal
          hrewrite IsolateNT.old⟩

```

## 終端記号分離の展開写像

分離後の記号を元の記号列へ展開する写像を定義し、形式全体へ `List.flatMap` で持ち上げる。新旧規則の一歩が展開後に元文法の導出になることを用いて逆包含を証明する。

```lean
@[grind] theorem isolateTerminals_language_forward
    (g : ContextFreeGrammar T) [DecidableEq T] [DecidableEq g.NT] :
    g.language ≤ (isolateTerminals g).language := by
  intro w hw
  have h := ContextFreeGrammar.derives_lift_of_produces
    (isolateTerminals_forward_step g) hw
  change (isolateTerminals g).Derives
    [Symbol.nonterminal (IsolateNT.old g.initial)]
    (List.map (Symbol.terminal :
      T → Symbol T (IsolateNT T g.NT)) w)
  simpa [Symbol.mapNonterminal, Function.comp_def] using h

def expandSymbol : Symbol T (IsolateNT T N) → List (Symbol T N)
  | .terminal a => [.terminal a]
  | .nonterminal (.old A) => [.nonterminal A]
  | .nonterminal (.terminal a) => [.terminal a]

def expandForm (xs : List (Symbol T (IsolateNT T N))) :
    List (Symbol T N) :=
  xs.flatMap expandSymbol

@[grind =, simp] theorem expand_isolateOutput (xs : List (Symbol T N)) :
    expandForm (isolateOutput xs) = xs := by
  induction xs with
  | nil => rfl
  | cons x xs ih =>
      cases x <;>
        change _ :: expandForm (isolateOutput xs) = _ :: xs <;>
        rw [ih]

@[grind =, simp] private theorem expand_map_old
    (xs : List (Symbol T N)) :
    expandForm (xs.map (Symbol.mapNonterminal IsolateNT.old)) = xs := by
  induction xs with
  | nil => rfl
  | cons x xs ih =>
      cases x <;>
        change _ :: expandForm
          (xs.map (Symbol.mapNonterminal IsolateNT.old)) = _ :: xs <;>
        rw [ih]

@[grind] theorem isolateTerminals_reverse_step
    (g : ContextFreeGrammar T) [DecidableEq T] [DecidableEq g.NT]
    {u v : List (Symbol T (IsolateNT T g.NT))}
    (h : (isolateTerminals g).Produces u v) :
    g.Derives (expandForm u) (expandForm v) := by
  rcases h with ⟨rule, hrule, hrewrite⟩
  rw [mem_isolateTerminals_rules_iff] at hrule
  rcases hrule with ⟨oldRule, hold, rfl⟩ |
      ⟨oldRule, hold, hlongGenerated, a, ha, rfl⟩
  · by_cases hlong : 2 ≤ oldRule.output.length
    · simp only [isolatedRule, if_pos hlong] at hrewrite
      obtain ⟨p, q, rfl, rfl⟩ := hrewrite.exists_parts
      have hsource :
          expandForm
            (p ++ [Symbol.nonterminal (IsolateNT.old oldRule.input)] ++ q) =
          expandForm p ++ [Symbol.nonterminal oldRule.input] ++
            expandForm q := by
        simp [expandForm, List.flatMap_append, expandSymbol]
      have htarget :
          expandForm (p ++ isolateOutput oldRule.output ++ q) =
          expandForm p ++ oldRule.output ++ expandForm q := by
        rw [expandForm, List.flatMap_append, List.flatMap_append]
        change expandForm p ++ expandForm (isolateOutput oldRule.output) ++
          expandForm q =
          expandForm p ++ oldRule.output ++ expandForm q
        rw [expand_isolateOutput]
      rw [hsource, htarget]
      exact ContextFreeGrammar.Produces.single
        ⟨oldRule, hold,
          ContextFreeRule.rewrites_of_exists_parts oldRule _ _⟩
    · simp only [isolatedRule, if_neg hlong,
        ContextFreeRule.mapNonterminal] at hrewrite
      obtain ⟨p, q, rfl, rfl⟩ := hrewrite.exists_parts
      have hsource :
          expandForm
            (p ++ [Symbol.nonterminal (IsolateNT.old oldRule.input)] ++ q) =
          expandForm p ++ [Symbol.nonterminal oldRule.input] ++
            expandForm q := by
        simp [expandForm, List.flatMap_append, expandSymbol]
      have htarget :
          expandForm
            (p ++ oldRule.output.map
              (Symbol.mapNonterminal IsolateNT.old) ++ q) =
          expandForm p ++ oldRule.output ++ expandForm q := by
        rw [expandForm, List.flatMap_append, List.flatMap_append]
        change expandForm p ++
          expandForm (oldRule.output.map
            (Symbol.mapNonterminal IsolateNT.old)) ++ expandForm q =
          expandForm p ++ oldRule.output ++ expandForm q
        rw [expand_map_old]
      rw [hsource, htarget]
      exact ContextFreeGrammar.Produces.single
        ⟨oldRule, hold,
          ContextFreeRule.rewrites_of_exists_parts oldRule _ _⟩
  · obtain ⟨p, q, rfl, rfl⟩ := hrewrite.exists_parts
    simpa [terminalIsolationRule, expandForm, List.flatMap_append,
      expandSymbol, List.append_assoc, List.singleton_append] using
      (ContextFreeGrammar.Derives.refl
        (g := g) (expandForm p ++
          Symbol.terminal a :: expandForm q))

@[grind] theorem isolateTerminals_reverse_derives
    (g : ContextFreeGrammar T) [DecidableEq T] [DecidableEq g.NT] :
    ∀ {u v : List (Symbol T (IsolateNT T g.NT))},
      (isolateTerminals g).Derives u v →
      g.Derives (expandForm u) (expandForm v) := by
  intro u v h
  induction h using Relation.ReflTransGen.head_induction_on with
  | refl => exact ContextFreeGrammar.Derives.refl _
  | head hstep _ ih =>
      exact (isolateTerminals_reverse_step g hstep).trans ih

@[grind] theorem expand_terminalSymbols (w : List T) :
    expandForm (terminalSymbols w :
      List (Symbol T (IsolateNT T N))) = terminalSymbols w := by
  induction w with
  | nil => rfl
  | cons a w ih =>
      change Symbol.terminal a ::
        expandForm (terminalSymbols w :
          List (Symbol T (IsolateNT T N))) =
        Symbol.terminal a :: terminalSymbols w
      rw [ih]

```

## 終端記号分離の言語保存と二分化用型

終端記号分離の双方向包含を言語等式にまとめる。続いて、元の非終端記号と長い右辺の suffix を区別して保持する `BinaryNT` を導入し、二分化段階の型境界を作る。

```lean
@[grind] theorem isolateTerminals_language_reverse
    (g : ContextFreeGrammar T) [DecidableEq T] [DecidableEq g.NT] :
    (isolateTerminals g).language ≤ g.language := by
  intro w hw
  have h := isolateTerminals_reverse_derives g hw
  change g.Derives
    (expandForm [Symbol.nonterminal (IsolateNT.old g.initial)])
    (expandForm (terminalSymbols w :
      List (Symbol T (IsolateNT T g.NT)))) at h
  have hinitial :
      expandForm
        ([Symbol.nonterminal (IsolateNT.old g.initial)] :
          List (Symbol T (IsolateNT T g.NT))) =
        [Symbol.nonterminal g.initial] := rfl
  rw [hinitial, expand_terminalSymbols] at h
  exact h

@[grind] theorem isolateTerminals_language (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] :
    (isolateTerminals g).language = g.language :=
  le_antisymm (isolateTerminals_language_reverse g)
    (isolateTerminals_language_forward g)

/-! ## Binarization of long nonterminal right-hand sides -/

@[grind cases] inductive BinaryNT (N : Type*) where
  | old (A : N)
  | tail (head : N) (suffix : List N)
deriving DecidableEq, Repr

def BinaryNT.orderKey : BinaryNT N → N ⊕ₗ (N ×ₗ List N)
  | .old A => Sum.inlₗ A
  | .tail A suffix => Sum.inrₗ (toLex (A, suffix))

instance [LinearOrder N] : LinearOrder (BinaryNT N) :=
  LinearOrder.lift' BinaryNT.orderKey (by
    intro x y h
    cases x <;> cases y <;> simp_all [BinaryNT.orderKey])

def symbolAsNonterminal : Symbol T N → Option N
  | .terminal _ => none
  | .nonterminal A => some A

def symbolsAsNonterminals : List (Symbol T N) → Option (List N)
  | [] => some []
  | x :: xs => do
      let A ← symbolAsNonterminal x
      let As ← symbolsAsNonterminals xs
      pure (A :: As)

def binarySymbols (ns : List N) :
    List (Symbol T (BinaryNT N)) :=
  ns.map (Symbol.nonterminal ∘ BinaryNT.old)

def tailSymbol (A : N) (suffix : List N) :
    Symbol T (BinaryNT N) :=
  Symbol.nonterminal (BinaryNT.tail A suffix)
def binarizeTailRules [DecidableEq T] [DecidableEq N] (A : N) :
    List N → Finset (ContextFreeRule T (BinaryNT N))
  | X :: Y :: [] =>
      { { input := BinaryNT.tail A [X, Y],
          output := binarySymbols [X, Y] } }
  | X :: Y :: Z :: rest =>
      insert
        { input := BinaryNT.tail A (X :: Y :: Z :: rest),
          output := [Symbol.nonterminal (BinaryNT.old X),
            tailSymbol A (Y :: Z :: rest)] }
        (binarizeTailRules A (Y :: Z :: rest))
  | _ => ∅
def binarizeLongRules [DecidableEq T] [DecidableEq N] (A : N) :
    List N → Finset (ContextFreeRule T (BinaryNT N))
  | X :: Y :: Z :: rest =>
      insert
        { input := BinaryNT.old A,
          output := [Symbol.nonterminal (BinaryNT.old X),
            tailSymbol A (Y :: Z :: rest)] }
        (binarizeTailRules A (Y :: Z :: rest))
  | _ => ∅

abbrev binarize (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] : ContextFreeGrammar T :=
  { NT := BinaryNT g.NT
    initial := BinaryNT.old g.initial
    rules := g.rules.biUnion fun r =>
        match r.output with
        | [] => {ContextFreeRule.mapNonterminal BinaryNT.old r}
        | [_] => {ContextFreeRule.mapNonterminal BinaryNT.old r}
        | [Symbol.nonterminal _, Symbol.nonterminal _] =>
            {ContextFreeRule.mapNonterminal BinaryNT.old r}
        | [_ , _] => ∅
        | _ :: _ :: _ :: _ =>
            match symbolsAsNonterminals r.output with
            | some ns => binarizeLongRules r.input ns
            | none => ∅ }
@[grind] theorem mem_binarize_rules_iff (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    (rule : ContextFreeRule T (binarize g).NT) :
    rule ∈ (binarize g).rules ↔
      ∃ oldRule ∈ g.rules,
        rule ∈
          match oldRule.output with
          | [] => {ContextFreeRule.mapNonterminal BinaryNT.old oldRule}
          | [_] => {ContextFreeRule.mapNonterminal BinaryNT.old oldRule}
          | [Symbol.nonterminal _, Symbol.nonterminal _] =>
              {ContextFreeRule.mapNonterminal BinaryNT.old oldRule}
          | [_, _] => ∅
          | _ :: _ :: _ :: _ =>
              match symbolsAsNonterminals oldRule.output with
              | some ns => binarizeLongRules oldRule.input ns
              | none => ∅ := by
  change rule ∈ g.rules.biUnion (fun oldRule =>
      match oldRule.output with
      | [] => {ContextFreeRule.mapNonterminal BinaryNT.old oldRule}
      | [_] => {ContextFreeRule.mapNonterminal BinaryNT.old oldRule}
      | [Symbol.nonterminal _, Symbol.nonterminal _] =>
          {ContextFreeRule.mapNonterminal BinaryNT.old oldRule}
      | [_, _] => ∅
      | _ :: _ :: _ :: _ =>
          match symbolsAsNonterminals oldRule.output with
          | some ns => binarizeLongRules oldRule.input ns
          | none => ∅) ↔ _
  exact Finset.mem_biUnion


```

## 二分化 tail の局所導出

長い右辺を連鎖状の二項規則へ分解したとき、各 suffix 用非終端記号が対応する残りの記号列を導出することを示す。Option を返す記号変換の成功条件も明示し、部分関数の失敗を規則形状で排除する。

```lean
@[grind] theorem symbolsAsNonterminals_eq_some
    {xs : List (Symbol T N)} {ns : List N}
    (h : symbolsAsNonterminals xs = some ns) :
    xs = ns.map Symbol.nonterminal := by
  induction xs generalizing ns with
  | nil =>
      simp [symbolsAsNonterminals] at h
      subst ns
      rfl
  | cons x xs ih =>
      cases x with
      | terminal a => simp [symbolsAsNonterminals, symbolAsNonterminal] at h
      | nonterminal A =>
          cases htail : symbolsAsNonterminals xs with
          | none =>
              simp [symbolsAsNonterminals, symbolAsNonterminal, htail] at h
          | some As =>
              simp [symbolsAsNonterminals, symbolAsNonterminal, htail] at h
              subst ns
              exact congrArg (Symbol.nonterminal A :: ·) (ih htail)

@[grind] theorem binarizeTail_derives
    (g : ContextFreeGrammar T) [DecidableEq T] [DecidableEq g.NT]
    (A : g.NT) :
    ∀ (X Y : g.NT) (rest : List g.NT),
      binarizeTailRules (T := T) A (X :: Y :: rest) ⊆
        (binarize g).rules →
      (binarize g).Derives [tailSymbol A (X :: Y :: rest)]
        (binarySymbols (T := T) (X :: Y :: rest)) := by
  intro X Y rest
  induction rest generalizing X Y with
  | nil =>
      intro hsub
      let rule : ContextFreeRule T (BinaryNT g.NT) :=
        { input := BinaryNT.tail A [X, Y],
          output := binarySymbols [X, Y] }
      apply ContextFreeGrammar.Produces.single
      refine ⟨rule, ?_, by
        change rule.Rewrites
          [Symbol.nonterminal rule.input] rule.output
        exact ContextFreeRule.Rewrites.input_output⟩
      apply hsub
      simp [binarizeTailRules, rule]
  | cons Z rest ih =>
      intro hsub
      have hfirst : (binarize g).Produces
          [tailSymbol A (X :: Y :: Z :: rest)]
          [Symbol.nonterminal (BinaryNT.old X),
            tailSymbol A (Y :: Z :: rest)] := by
        let rule : ContextFreeRule T (BinaryNT g.NT) :=
          { input := BinaryNT.tail A (X :: Y :: Z :: rest),
            output := [Symbol.nonterminal (BinaryNT.old X),
              tailSymbol A (Y :: Z :: rest)] }
        refine ⟨rule, ?_, by
          change rule.Rewrites
            [Symbol.nonterminal rule.input] rule.output
          exact ContextFreeRule.Rewrites.input_output⟩
        apply hsub
        simp [binarizeTailRules, rule]
      have htailSubset :
          binarizeTailRules (T := T) A (Y :: Z :: rest) ⊆
            (binarize g).rules := by
        intro rule hrule
        apply hsub
        simp only [binarizeTailRules, Finset.mem_insert]
        exact Or.inr hrule
      have htail := ih Y Z htailSubset
      have htail' :=
        htail.append_left [Symbol.nonterminal (BinaryNT.old X)]
      change (binarize g).Derives
        [Symbol.nonterminal (BinaryNT.old X), tailSymbol A (Y :: Z :: rest)]
        (binarySymbols (T := T) (X :: Y :: Z :: rest)) at htail'
      exact hfirst.single.trans htail'
@[grind] theorem symbolsAsNonterminals_some_of_all
    (xs : List (Symbol T N)) (h : allNonterminals xs) :
    ∃ ns, symbolsAsNonterminals xs = some ns := by
  induction xs with
  | nil => exact ⟨[], rfl⟩
  | cons x xs ih =>
      have hx := h x (by simp)
      cases x with
      | terminal a => exact hx.elim
      | nonterminal A =>
          obtain ⟨As, hAs⟩ := ih fun y hy =>
            h y (List.mem_cons_of_mem _ hy)
          exact ⟨A :: As, by
            simp [symbolsAsNonterminals, symbolAsNonterminal, hAs]⟩

@[grind =, simp] private theorem symbolsAsNonterminals_map_nonterminal
    (ns : List N) :
    symbolsAsNonterminals (T := T) (ns.map Symbol.nonterminal) = some ns := by
  induction ns with
  | nil => rfl
  | cons A ns ih =>
      simp [symbolsAsNonterminals, symbolAsNonterminal, ih]

@[grind] theorem binarize_old_rule_derives (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    {r : ContextFreeRule T g.NT} (hr : r ∈ g.rules)
    (hall : 2 ≤ r.output.length → allNonterminals r.output) :
    (binarize g).Derives
      [Symbol.nonterminal (BinaryNT.old r.input)]
      (r.output.map (Symbol.mapNonterminal BinaryNT.old)) := by
  by_cases hlong : 3 ≤ r.output.length
  · obtain ⟨ns, hns⟩ :=
      symbolsAsNonterminals_some_of_all r.output
        (hall (by omega))
    have hout := symbolsAsNonterminals_eq_some hns
    rw [hout] at hlong ⊢
    cases ns with
    | nil => simp at hlong
    | cons X ns =>
        cases ns with
        | nil => simp at hlong
        | cons Y ns =>
            cases ns with
            | nil => simp at hlong
            | cons Z rest =>
                have hfirstMem :
                    ({ input := BinaryNT.old r.input,
                       output := [Symbol.nonterminal (BinaryNT.old X),
                         tailSymbol r.input (Y :: Z :: rest)] } :
                      ContextFreeRule T (BinaryNT g.NT)) ∈
                      (binarize g).rules := by
                  change _ ∈ g.rules.biUnion fun oldRule =>
                    match oldRule.output with
                    | [] => {ContextFreeRule.mapNonterminal BinaryNT.old oldRule}
                    | [_] => {ContextFreeRule.mapNonterminal BinaryNT.old oldRule}
                    | [Symbol.nonterminal _, Symbol.nonterminal _] =>
                        {ContextFreeRule.mapNonterminal BinaryNT.old oldRule}
                    | [_, _] => ∅
                    | _ :: _ :: _ :: _ =>
                        match symbolsAsNonterminals oldRule.output with
                        | some ns => binarizeLongRules oldRule.input ns
                        | none => ∅
                  apply Finset.mem_biUnion.mpr
                  refine ⟨r, hr, ?_⟩
                  rw [hout]
                  have hcompute :
                      symbolsAsNonterminals (T := T)
                        ((X :: Y :: Z :: rest).map
                          (Symbol.nonterminal (T := T))) =
                          some (X :: Y :: Z :: rest) :=
                    symbolsAsNonterminals_map_nonterminal (T := T) _
                  rw [hcompute]
                  simp [binarizeLongRules]
                have hfirst : (binarize g).Produces
                    [Symbol.nonterminal (BinaryNT.old r.input)]
                    [Symbol.nonterminal (BinaryNT.old X),
                      tailSymbol r.input (Y :: Z :: rest)] :=
                  ⟨_, hfirstMem, ContextFreeRule.Rewrites.input_output⟩
                have htailSubset :
                    binarizeTailRules (T := T) r.input (Y :: Z :: rest) ⊆
                      (binarize g).rules := by
                  intro newRule hrule
                  change newRule ∈ g.rules.biUnion fun oldRule =>
                    match oldRule.output with
                    | [] => {ContextFreeRule.mapNonterminal BinaryNT.old oldRule}
                    | [_] => {ContextFreeRule.mapNonterminal BinaryNT.old oldRule}
                    | [Symbol.nonterminal _, Symbol.nonterminal _] =>
                        {ContextFreeRule.mapNonterminal BinaryNT.old oldRule}
                    | [_, _] => ∅
                    | _ :: _ :: _ :: _ =>
                        match symbolsAsNonterminals oldRule.output with
                        | some ns => binarizeLongRules oldRule.input ns
                        | none => ∅
                  apply Finset.mem_biUnion.mpr
                  refine ⟨r, hr, ?_⟩
                  rw [hout]
                  have hcompute :
                      symbolsAsNonterminals (T := T)
                        ((X :: Y :: Z :: rest).map
                          (Symbol.nonterminal (T := T))) =
                          some (X :: Y :: Z :: rest) :=
                    symbolsAsNonterminals_map_nonterminal (T := T) _
                  rw [hcompute]
                  simp [binarizeLongRules]
                  exact Or.inr hrule
                have htail :=
                  binarizeTail_derives g r.input Y Z rest htailSubset
                have htail' :=
                  htail.append_left [Symbol.nonterminal (BinaryNT.old X)]
                have htail'' : (binarize g).Derives
                    [Symbol.nonterminal (BinaryNT.old X),
                      tailSymbol r.input (Y :: Z :: rest)]
                    (List.map (Symbol.mapNonterminal BinaryNT.old)
                      (List.map (Symbol.nonterminal (T := T))
                        (X :: Y :: Z :: rest))) := by
                  simpa [binarySymbols, Function.comp_def] using htail'
                exact hfirst.single.trans htail''
  · have hshort : r.output.length < 3 := by omega
    apply ContextFreeGrammar.Produces.single
    refine ⟨ContextFreeRule.mapNonterminal BinaryNT.old r, ?_,
      ContextFreeRule.Rewrites.input_output⟩
    change ContextFreeRule.mapNonterminal BinaryNT.old r ∈
      g.rules.biUnion fun oldRule =>
        match oldRule.output with
        | [] => {ContextFreeRule.mapNonterminal BinaryNT.old oldRule}
        | [_] => {ContextFreeRule.mapNonterminal BinaryNT.old oldRule}
        | [Symbol.nonterminal _, Symbol.nonterminal _] =>
            {ContextFreeRule.mapNonterminal BinaryNT.old oldRule}
        | [_, _] => ∅
        | _ :: _ :: _ :: _ =>
            match symbolsAsNonterminals oldRule.output with
            | some ns => binarizeLongRules oldRule.input ns
            | none => ∅
    apply Finset.mem_biUnion.mpr
    refine ⟨r, hr, ?_⟩
    cases hout : r.output with
    | nil => simp [hout]
    | cons x xs =>
        cases xs with
        | nil => simp [hout]
        | cons y ys =>
            cases ys with
            | nil =>
                have hAll := hall (by simp [hout])
                cases x with
                | terminal a =>
                    have hfalse := hAll (Symbol.terminal a) (by simp [hout])
                    exact hfalse.elim
                | nonterminal A =>
                    cases y with
                    | terminal b =>
                        have hfalse := hAll (Symbol.terminal b) (by simp [hout])
                        exact hfalse.elim
                    | nonterminal B => simp [hout]
            | cons z rest =>
                have hlength :
                    r.output.length = (x :: y :: z :: rest).length :=
                  congrArg List.length hout
                simp at hlength
                omega

```

## 二分化の順向き保存と展開

元の長い規則一歩を二分化規則列で模倣し、言語の順向き包含を得る。逆方向のため、補助非終端記号を元の suffix へ展開する写像を記号列全体に定義する。

```lean
@[grind] theorem binarize_forward_step (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    (hall : ∀ r ∈ g.rules, 2 ≤ r.output.length →
      allNonterminals r.output)
    {u v : List (Symbol T g.NT)} (h : g.Produces u v) :
    (binarize g).Derives
      (u.map (Symbol.mapNonterminal BinaryNT.old))
      (v.map (Symbol.mapNonterminal BinaryNT.old)) := by
  rcases h with ⟨r, hr, hrewrite⟩
  obtain ⟨p, q, rfl, rfl⟩ := hrewrite.exists_parts
  have hmiddle := binarize_old_rule_derives g hr (hall r hr)
  simpa [List.map_append, List.append_assoc] using
    (hmiddle.append_left
      (p.map (Symbol.mapNonterminal BinaryNT.old))).append_right
        (q.map (Symbol.mapNonterminal BinaryNT.old))

@[grind] theorem binarize_language_forward (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    (hall : ∀ r ∈ g.rules, 2 ≤ r.output.length →
      allNonterminals r.output) :
    g.language ≤ (binarize g).language := by
  intro w hw
  have h := ContextFreeGrammar.derives_lift_of_produces
    (binarize_forward_step g hall) hw
  change (binarize g).Derives
    [Symbol.nonterminal (BinaryNT.old g.initial)]
    (List.map (Symbol.terminal : T → Symbol T (BinaryNT g.NT)) w)
  convert h using 1 <;> simp [Symbol.mapNonterminal]

def expandBinarySymbol :
    Symbol T (BinaryNT N) → List (Symbol T N)
  | .terminal a => [Symbol.terminal a]
  | .nonterminal (.old A) => [Symbol.nonterminal A]
  | .nonterminal (.tail _ suffix) => suffix.map Symbol.nonterminal

def expandBinaryForm
    (xs : List (Symbol T (BinaryNT N))) : List (Symbol T N) :=
  xs.flatMap expandBinarySymbol

@[grind =, simp] private theorem expandBinaryForm_append
    (xs ys : List (Symbol T (BinaryNT N))) :
    expandBinaryForm (xs ++ ys) =
      expandBinaryForm xs ++ expandBinaryForm ys := by
  simp [expandBinaryForm]

@[grind =, simp] private theorem expandBinaryForm_map_old
    (xs : List (Symbol T N)) :
    expandBinaryForm
      (xs.map (Symbol.mapNonterminal BinaryNT.old)) = xs := by
  induction xs with
  | nil => rfl
  | cons x xs ih =>
      cases x with
      | terminal a =>
          change Symbol.terminal a ::
            expandBinaryForm
              (xs.map (Symbol.mapNonterminal BinaryNT.old)) =
                Symbol.terminal a :: xs
          exact congrArg (Symbol.terminal a :: ·) ih
      | nonterminal A =>
          change Symbol.nonterminal A ::
            expandBinaryForm
              (xs.map (Symbol.mapNonterminal BinaryNT.old)) =
                Symbol.nonterminal A :: xs
          exact congrArg (Symbol.nonterminal A :: ·) ih

@[grind =, simp] private theorem expandBinaryForm_old_singleton
    (A : N) :
    expandBinaryForm (T := T)
      [Symbol.nonterminal (T := T) (BinaryNT.old A)] =
        [Symbol.nonterminal (T := T) A] := rfl

@[grind =, simp] private theorem expandBinaryForm_terminalSymbols
    (w : List T) :
    expandBinaryForm
      (terminalSymbols (N := BinaryNT N) w) =
        terminalSymbols (N := N) w := by
  induction w with
  | nil => rfl
  | cons a w ih =>
      change Symbol.terminal a ::
        expandBinaryForm (terminalSymbols (N := BinaryNT N) w) =
          Symbol.terminal a :: terminalSymbols (N := N) w
      exact congrArg (Symbol.terminal a :: ·) ih

@[grind] theorem expand_binarizeTailRule_eq [DecidableEq T] [DecidableEq N]
    (A : N) :
    ∀ (X Y : N) (rest : List N)
      (rule : ContextFreeRule T (BinaryNT N)),
      rule ∈ binarizeTailRules (T := T) A (X :: Y :: rest) →
      expandBinaryForm [Symbol.nonterminal rule.input] =
        expandBinaryForm rule.output := by
  intro X Y rest
  induction rest generalizing X Y with
  | nil =>
      intro rule hrule
      simp only [binarizeTailRules, Finset.mem_singleton] at hrule
      subst rule
      rfl
  | cons Z rest ih =>
      intro rule hrule
      simp only [binarizeTailRules, Finset.mem_insert] at hrule
      rcases hrule with rfl | hrule
      · rfl
      · exact ih Y Z rule hrule


@[grind] theorem binarize_copied_rule_reverse (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    {r : ContextFreeRule T g.NT} (hr : r ∈ g.rules) :
    g.Derives
      (expandBinaryForm
        [Symbol.nonterminal
          (ContextFreeRule.mapNonterminal BinaryNT.old r).input])
      (expandBinaryForm
        (ContextFreeRule.mapNonterminal BinaryNT.old r).output) := by
  change g.Derives [Symbol.nonterminal r.input]
    (expandBinaryForm
      (r.output.map (Symbol.mapNonterminal BinaryNT.old)))
  rw [expandBinaryForm_map_old]
  exact ContextFreeGrammar.Produces.single
    ⟨r, hr, ContextFreeRule.Rewrites.input_output⟩

```

## 二分化規則の逆向き保存

二分化で生成される各種類の規則を、展開後の元文法導出へ戻す。局所補題を導出列に持ち上げて逆包含を証明し、二分化前後の言語等式を得る。

```lean
@[grind] theorem binarize_rule_reverse (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    {rule : ContextFreeRule T (BinaryNT g.NT)}
    (hrule : rule ∈ (binarize g).rules) :
    g.Derives
      (expandBinaryForm [Symbol.nonterminal rule.input])
      (expandBinaryForm rule.output) := by
  rw [mem_binarize_rules_iff] at hrule
  obtain ⟨oldRule, hold, hgenerated⟩ := hrule
  cases hout : oldRule.output with
  | nil =>
      simp [hout] at hgenerated
      subst rule
      exact binarize_copied_rule_reverse g hold
  | cons x xs =>
      cases xs with
      | nil =>
          simp [hout] at hgenerated
          subst rule
          exact binarize_copied_rule_reverse g hold
      | cons y ys =>
          cases ys with
          | nil =>
              cases x with
              | terminal a =>
                  cases y <;> simp [hout] at hgenerated
              | nonterminal A =>
                  cases y with
                  | terminal b => simp [hout] at hgenerated
                  | nonterminal B =>
                      simp [hout] at hgenerated
                      subst rule
                      exact binarize_copied_rule_reverse g hold
          | cons z rest =>
              rw [hout] at hgenerated
              cases hsymbols :
                  symbolsAsNonterminals (x :: y :: z :: rest) with
              | none => simp [hsymbols] at hgenerated
              | some ns =>
                  have hnonterminals :=
                    symbolsAsNonterminals_eq_some hsymbols
                  simp only [hsymbols] at hgenerated
                  cases ns with
                  | nil => simp [binarizeLongRules] at hgenerated
                  | cons X ns =>
                      cases ns with
                      | nil => simp [binarizeLongRules] at hgenerated
                      | cons Y ns =>
                          cases ns with
                          | nil => simp [binarizeLongRules] at hgenerated
                          | cons Z suffix =>
                              simp only [binarizeLongRules,
                                Finset.mem_insert] at hgenerated
                              rcases hgenerated with hfirst | htail
                              · subst rule
                                have hproduce : g.Derives
                                    [Symbol.nonterminal oldRule.input]
                                    oldRule.output :=
                                  ContextFreeGrammar.Produces.single
                                    ⟨oldRule, hold,
                                      ContextFreeRule.Rewrites.input_output⟩
                                have hexpand :
                                    expandBinaryForm
                                      [Symbol.nonterminal (BinaryNT.old X),
                                        tailSymbol oldRule.input
                                          (Y :: Z :: suffix)] =
                                      oldRule.output := by
                                  rw [hout, hnonterminals]
                                  simp [expandBinaryForm,
                                    expandBinarySymbol, tailSymbol]
                                rw [hexpand]
                                exact hproduce
                              · rw [expand_binarizeTailRule_eq
                                  oldRule.input Y Z suffix rule htail]

@[grind] theorem binarize_reverse_step (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    {u v : List (Symbol T (BinaryNT g.NT))}
    (h : (binarize g).Produces u v) :
    g.Derives (expandBinaryForm u) (expandBinaryForm v) := by
  rcases h with ⟨rule, hrule, hrewrite⟩
  obtain ⟨p, q, rfl, rfl⟩ := hrewrite.exists_parts
  have hmiddle := binarize_rule_reverse g hrule
  unfold expandBinaryForm at hmiddle ⊢
  simpa only [List.flatMap_append, List.append_assoc] using
    (hmiddle.append_left (List.flatMap expandBinarySymbol p)).append_right
      (List.flatMap expandBinarySymbol q)
@[grind] theorem binarize_derives_reverse (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    {u v : List (Symbol T (BinaryNT g.NT))}
    (h : (binarize g).Derives u v) :
    g.Derives (expandBinaryForm u) (expandBinaryForm v) := by
  induction h with
  | refl => exact ContextFreeGrammar.Derives.refl _
  | tail hder hstep ih =>
      exact ih.trans (binarize_reverse_step g hstep)

@[grind] theorem binarize_language_reverse (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT] :
    (binarize g).language ≤ g.language := by
  intro w hw
  have hsim := binarize_derives_reverse g hw
  change g.Derives
    (expandBinaryForm
      [Symbol.nonterminal (T := T) (BinaryNT.old g.initial)])
    (expandBinaryForm (terminalSymbols (N := BinaryNT g.NT) w)) at hsim
  rw [expandBinaryForm_old_singleton,
    expandBinaryForm_terminalSymbols] at hsim
  exact hsim
@[grind] theorem binarizeTailRules_binary [DecidableEq T] [DecidableEq N]
    (A : N) :
    ∀ (X Y : N) (rest : List N)
      (rule : ContextFreeRule T (BinaryNT N)),
      rule ∈ binarizeTailRules (T := T) A (X :: Y :: rest) →
      ∃ B C, rule.output =
        [Symbol.nonterminal B, Symbol.nonterminal C] := by
  intro X Y rest
  induction rest generalizing X Y with
  | nil =>
      intro rule hrule
      simp only [binarizeTailRules, Finset.mem_singleton] at hrule
      subst rule
      exact ⟨BinaryNT.old X, BinaryNT.old Y, rfl⟩
  | cons Z rest ih =>
      intro rule hrule
      simp only [binarizeTailRules, Finset.mem_insert] at hrule
      rcases hrule with rfl | hrule
      · exact ⟨BinaryNT.old X, BinaryNT.tail A (Y :: Z :: rest), rfl⟩
      · exact ih Y Z rule hrule

```

## Chomsky 規則形状の確立

二分化後の全規則が、終端一個または非終端二個という Chomsky 形状を満たすことを示す。長い suffix 用の補助規則と旧規則由来のケースを分けて検証する。

```lean
@[grind] theorem binarizeLongRules_binary [DecidableEq T] [DecidableEq N]
    (A : N)
    {ns : List N} {rule : ContextFreeRule T (BinaryNT N)}
    (hrule : rule ∈ binarizeLongRules (T := T) A ns) :
    ∃ B C, rule.output =
      [Symbol.nonterminal B, Symbol.nonterminal C] := by
  cases ns with
  | nil => simp [binarizeLongRules] at hrule
  | cons X ns =>
      cases ns with
      | nil => simp [binarizeLongRules] at hrule
      | cons Y ns =>
          cases ns with
          | nil => simp [binarizeLongRules] at hrule
          | cons Z rest =>
              simp only [binarizeLongRules, Finset.mem_insert] at hrule
              rcases hrule with rfl | hrule
              · exact ⟨BinaryNT.old X,
                  BinaryNT.tail A (Y :: Z :: rest), rfl⟩
              · exact binarizeTailRules_binary A Y Z rest rule hrule

@[grind] theorem binarize_is_chomsky (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    (hε : ∀ r ∈ g.rules, r.output = [] → r.input = g.initial)
    (hunit : ∀ r ∈ g.rules, ¬IsUnitRule r)
    (_hall : ∀ r ∈ g.rules, 2 ≤ r.output.length →
      allNonterminals r.output) :
    ∀ r ∈ (binarize g).rules,
      ContextFreeRule.IsChomskyNormal (binarize g).initial r := by
  intro rule hrule
  rw [mem_binarize_rules_iff] at hrule
  obtain ⟨oldRule, hold, hgenerated⟩ := hrule
  cases hout : oldRule.output with
  | nil =>
      simp [hout] at hgenerated
      subst rule
      left
      constructor
      · change BinaryNT.old oldRule.input = BinaryNT.old g.initial
        exact congrArg BinaryNT.old (hε oldRule hold hout)
      · simp [ContextFreeRule.mapNonterminal, hout]
  | cons x xs =>
      cases xs with
      | nil =>
          simp [hout] at hgenerated
          subst rule
          cases x with
          | terminal a =>
              exact Or.inr (Or.inl ⟨a, by
                simp [ContextFreeRule.mapNonterminal, hout]⟩)
          | nonterminal A =>
              exact (hunit oldRule hold ⟨A, hout⟩).elim
      | cons y ys =>
          cases ys with
          | nil =>
              cases x with
              | terminal a => cases y <;> simp [hout] at hgenerated
              | nonterminal A =>
                  cases y with
                  | terminal b => simp [hout] at hgenerated
                  | nonterminal B =>
                      simp [hout] at hgenerated
                      subst rule
                      exact Or.inr (Or.inr ⟨BinaryNT.old A,
                        BinaryNT.old B, by
                          simp [ContextFreeRule.mapNonterminal, hout]⟩)
          | cons z rest =>
              rw [hout] at hgenerated
              cases hsymbols :
                  symbolsAsNonterminals (x :: y :: z :: rest) with
              | none => simp [hsymbols] at hgenerated
              | some ns =>
                  simp only [hsymbols] at hgenerated
                  obtain ⟨B, C, houtput⟩ :=
                    binarizeLongRules_binary oldRule.input hgenerated
                  exact Or.inr (Or.inr ⟨B, C, houtput⟩)
@[grind] theorem old_mem_binarizeTail_output [DecidableEq T] [DecidableEq N]
    (A : N) :
    ∀ (X Y : N) (rest : List N)
      (rule : ContextFreeRule T (BinaryNT N)),
      rule ∈ binarizeTailRules (T := T) A (X :: Y :: rest) →
      ∀ {B}, Symbol.nonterminal (BinaryNT.old B) ∈ rule.output →
        B ∈ X :: Y :: rest := by
  intro X Y rest
  induction rest generalizing X Y with
  | nil =>
      intro rule hrule B hmem
      simp only [binarizeTailRules, Finset.mem_singleton] at hrule
      subst rule
      simpa [binarySymbols, Function.comp_def] using hmem
  | cons Z rest ih =>
      intro rule hrule B hmem
      simp only [binarizeTailRules, Finset.mem_insert] at hrule
      rcases hrule with rfl | hrule
      · have hBX : B = X := by simpa [tailSymbol] using hmem
        exact List.mem_cons.mpr (Or.inl hBX)
      · exact List.mem_cons_of_mem X (ih Y Z rule hrule hmem)

@[grind] theorem old_mem_binarizeLong_output [DecidableEq T] [DecidableEq N]
    (A : N)
    {ns : List N} {rule : ContextFreeRule T (BinaryNT N)}
    (hrule : rule ∈ binarizeLongRules (T := T) A ns)
    {B : N} (hmem : Symbol.nonterminal (BinaryNT.old B) ∈ rule.output) :
    B ∈ ns := by
  cases ns with
  | nil => simp [binarizeLongRules] at hrule
  | cons X ns =>
      cases ns with
      | nil => simp [binarizeLongRules] at hrule
      | cons Y ns =>
          cases ns with
          | nil => simp [binarizeLongRules] at hrule
          | cons Z rest =>
              simp only [binarizeLongRules, Finset.mem_insert] at hrule
              rcases hrule with rfl | hrule
              · have hBX : B = X := by simpa [tailSymbol] using hmem
                exact List.mem_cons.mpr (Or.inl hBX)
              · exact List.mem_cons_of_mem X
                  (old_mem_binarizeTail_output A Y Z rest rule hrule hmem)

```

## 二分化後の初期記号不変条件

補助非終端記号への埋め込みが元の初期記号と衝突しないことを示し、二分化後の右辺に初期記号が現れない性質を保存する。unit 到達が初期記号へ戻れないこともここで確立する。

```lean
@[grind] theorem old_mem_map_binary_old
    {A : N} {xs : List (Symbol T N)}
    (hmem : Symbol.nonterminal (BinaryNT.old A) ∈
      xs.map (Symbol.mapNonterminal BinaryNT.old)) :
    Symbol.nonterminal A ∈ xs := by
  obtain ⟨x, hx, heq⟩ := List.mem_map.mp hmem
  cases x with
  | terminal a => cases heq
  | nonterminal B =>
      have hBA : B = A := by simpa using heq
      subst B
      exact hx

@[grind] theorem binarize_initial_not_output (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    (h : ∀ r ∈ g.rules,
      Symbol.nonterminal g.initial ∉ r.output) :
    ∀ r ∈ (binarize g).rules,
      Symbol.nonterminal (binarize g).initial ∉ r.output := by
  intro rule hrule hmem
  rw [mem_binarize_rules_iff] at hrule
  obtain ⟨oldRule, hold, hgenerated⟩ := hrule
  cases hout : oldRule.output with
  | nil =>
      simp [hout] at hgenerated
      subst rule
      exact h oldRule hold (old_mem_map_binary_old hmem)
  | cons x xs =>
      cases xs with
      | nil =>
          simp [hout] at hgenerated
          subst rule
          exact h oldRule hold (old_mem_map_binary_old hmem)
      | cons y ys =>
          cases ys with
          | nil =>
              cases x with
              | terminal a => cases y <;> simp [hout] at hgenerated
              | nonterminal A =>
                  cases y with
                  | terminal b => simp [hout] at hgenerated
                  | nonterminal B =>
                      simp [hout] at hgenerated
                      subst rule
                      exact h oldRule hold (old_mem_map_binary_old hmem)
          | cons z rest =>
              rw [hout] at hgenerated
              cases hsymbols :
                  symbolsAsNonterminals (x :: y :: z :: rest) with
              | none => simp [hsymbols] at hgenerated
              | some ns =>
                  have hnonterminals :=
                    symbolsAsNonterminals_eq_some hsymbols
                  simp only [hsymbols] at hgenerated
                  have hinitial :
                      g.initial ∈ ns :=
                    old_mem_binarizeLong_output oldRule.input
                      hgenerated hmem
                  apply h oldRule hold
                  rw [hout, hnonterminals]
                  exact List.mem_map.mpr
                    ⟨g.initial, hinitial, rfl⟩


@[grind] theorem unitReach_to_initial_eq (g : ContextFreeGrammar T)
    (hnot : ∀ r ∈ g.rules,
      Symbol.nonterminal g.initial ∉ r.output)
    {A B : g.NT} (hreach : UnitReach g A B)
    (hB : B = g.initial) : A = g.initial := by
  rcases hreach.cases_tail with heq | ⟨C, _, hstep⟩
  · exact heq.symm.trans hB
  · exfalso
    apply hnot
      ({ input := C, output := [Symbol.nonterminal B] } :
        ContextFreeRule T g.NT) hstep
    simpa [hB]

@[grind] theorem removeUnit_no_noninitial_empty (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    (hε : ∀ r ∈ g.rules, r.output = [] → r.input = g.initial)
    (hnot : ∀ r ∈ g.rules,
      Symbol.nonterminal g.initial ∉ r.output) :
    ∀ r ∈ (removeUnit g).rules,
      r.output = [] → r.input = (removeUnit g).initial := by
  intro rule hrule hout
  simp only [removeUnit, Finset.mem_biUnion, Finset.mem_filter,
    Finset.mem_image] at hrule
  obtain ⟨⟨A, B⟩, ⟨hactive, hreachMem⟩, oldRule,
    ⟨hold, ⟨hinput, _⟩⟩, rfl⟩ := hrule
  have hreach : UnitReach g A B :=
    (mem_unitReachSet_iff g (Finset.mem_product.mp hactive).1).mp hreachMem
  change oldRule.input = B at hinput
  change oldRule.output = [] at hout
  have hB : B = g.initial :=
    hinput.symm.trans (hε oldRule hold hout)
  exact unitReach_to_initial_eq g hnot hreach hB

@[grind] theorem old_mem_isolateOutput
    {A : N} {xs : List (Symbol T N)}
    (h : Symbol.nonterminal (IsolateNT.old A) ∈ isolateOutput xs) :
    Symbol.nonterminal A ∈ xs := by
  induction xs with
  | nil => simp [isolateOutput] at h
  | cons x xs ih =>
      cases x with
      | terminal a =>
          simp only [isolateOutput, List.mem_cons] at h
          rcases h with hhead | htail
          · cases hhead
          · exact List.mem_cons_of_mem _ (ih htail)
      | nonterminal B =>
          simp only [isolateOutput, List.mem_cons] at h
          rcases h with hhead | htail
          · cases hhead
            exact List.mem_cons_self
          · exact List.mem_cons_of_mem _ (ih htail)

@[grind] theorem isolateOutput_allNonterminals
    (xs : List (Symbol T N)) :
    allNonterminals (isolateOutput xs) := by
  intro x hx
  induction xs with
  | nil => simp [isolateOutput] at hx
  | cons x xs ih =>
      cases x <;>
        simp only [isolateOutput, List.mem_cons] at hx <;>
        rcases hx with rfl | htail
      · trivial
      · exact ih htail
      · trivial
      · exact ih htail

@[grind =, simp] theorem isolateOutput_length
    (xs : List (Symbol T N)) :
    (isolateOutput xs).length = xs.length := by
  induction xs with
  | nil => rfl
  | cons x xs ih => cases x <;> simp [isolateOutput, ih]

```

## 終端分離後の初期記号と ε 不変条件

終端分離で導入する新記号が初期記号と異なること、初期記号が右辺へ再導入されないこと、非初期の空規則が生じないことを証明する。最終合成に必要な側条件をこの段階で閉じる。

```lean
@[grind] theorem old_mem_map_isolateOld
    {A : N} {xs : List (Symbol T N)}
    (hmem : Symbol.nonterminal
        ((IsolateNT.old : N → IsolateNT T N) A) ∈
      xs.map (Symbol.mapNonterminal
        (IsolateNT.old : N → IsolateNT T N))) :
    Symbol.nonterminal A ∈ xs := by
  obtain ⟨x, hx, heq⟩ := List.mem_map.mp hmem
  cases x with
  | terminal a => cases heq
  | nonterminal B =>
      cases heq
      exact hx

@[grind] theorem isolateTerminals_initial_not_output
    (g : ContextFreeGrammar T) [DecidableEq T] [DecidableEq g.NT]
    (hnot : ∀ r ∈ g.rules,
      Symbol.nonterminal g.initial ∉ r.output) :
    ∀ r ∈ (isolateTerminals g).rules,
      Symbol.nonterminal (isolateTerminals g).initial ∉ r.output := by
  intro rule hrule hmem
  rw [mem_isolateTerminals_rules_iff] at hrule
  rcases hrule with ⟨oldRule, hold, rfl⟩ |
      ⟨oldRule, hold, hlong, a, ha, rfl⟩
  · by_cases hlong : 2 ≤ oldRule.output.length
    · simp only [isolatedRule, if_pos hlong] at hmem
      exact hnot oldRule hold (old_mem_isolateOutput hmem)
    · simp only [isolatedRule, if_neg hlong,
        ContextFreeRule.mapNonterminal] at hmem
      exact hnot oldRule hold (old_mem_map_isolateOld hmem)
  · simp [terminalIsolationRule] at hmem

@[grind] theorem isolateTerminals_no_noninitial_empty
    (g : ContextFreeGrammar T) [DecidableEq T] [DecidableEq g.NT]
    (hε : ∀ r ∈ g.rules, r.output = [] → r.input = g.initial) :
    ∀ r ∈ (isolateTerminals g).rules,
      r.output = [] → r.input = (isolateTerminals g).initial := by
  intro rule hrule hout
  rw [mem_isolateTerminals_rules_iff] at hrule
  rcases hrule with ⟨oldRule, hold, rfl⟩ |
      ⟨oldRule, hold, hlongGenerated, a, ha, rfl⟩
  · by_cases hlong : 2 ≤ oldRule.output.length
    · simp only [isolatedRule, if_pos hlong] at hout
      have hlen := congrArg List.length hout
      rw [isolateOutput_length] at hlen
      rw [hlen] at hlong
      simp at hlong
    · simp only [isolatedRule, if_neg hlong,
        ContextFreeRule.mapNonterminal] at hout ⊢
      have holdEmpty : oldRule.output = [] := by
        simpa using hout
      exact congrArg IsolateNT.old (hε oldRule hold holdEmpty)
  · simp [terminalIsolationRule] at hout

@[grind] theorem isolateTerminals_no_unit
    (g : ContextFreeGrammar T) [DecidableEq T] [DecidableEq g.NT]
    (hunit : ∀ r ∈ g.rules, ¬IsUnitRule r) :
    ∀ r ∈ (isolateTerminals g).rules, ¬IsUnitRule r := by
  intro rule hrule hunitRule
  rw [mem_isolateTerminals_rules_iff] at hrule
  rcases hrule with ⟨oldRule, hold, rfl⟩ |
      ⟨oldRule, hold, hlongGenerated, a, ha, rfl⟩
  · by_cases hlong : 2 ≤ oldRule.output.length
    · simp only [isolatedRule, if_pos hlong] at hunitRule
      obtain ⟨B, houtput⟩ := hunitRule
      have hlen := congrArg List.length houtput
      rw [isolateOutput_length] at hlen
      have : oldRule.output.length = 1 := by simpa using hlen
      omega
    · simp only [isolatedRule, if_neg hlong] at hunitRule
      obtain ⟨B, houtput⟩ := hunitRule
      change oldRule.output.map
        (Symbol.mapNonterminal IsolateNT.old) =
          [Symbol.nonterminal B] at houtput
      apply hunit oldRule hold
      cases hout : oldRule.output with
      | nil =>
          rw [hout] at houtput
          simp [ContextFreeRule.mapNonterminal] at houtput
      | cons x xs =>
          cases xs with
          | nil =>
              cases x with
              | terminal a =>
                  cases B <;>
                    simp [ContextFreeRule.mapNonterminal, hout] at houtput
              | nonterminal A => exact ⟨A, hout⟩
          | cons y ys =>
              have hlen := congrArg List.length houtput
              simp [ContextFreeRule.mapNonterminal, hout] at hlen
  · rcases hunitRule with ⟨B, houtput⟩
    cases B <;> simp [terminalIsolationRule] at houtput

@[grind] theorem isolateTerminals_long_rhs_all_nonterminals
    (g : ContextFreeGrammar T) [DecidableEq T] [DecidableEq g.NT] :
    ∀ r ∈ (isolateTerminals g).rules,
      2 ≤ r.output.length → allNonterminals r.output := by
  intro rule hrule hlen
  rw [mem_isolateTerminals_rules_iff] at hrule
  rcases hrule with ⟨oldRule, hold, rfl⟩ |
      ⟨oldRule, hold, hlongGenerated, a, ha, rfl⟩
  · by_cases hlong : 2 ≤ oldRule.output.length
    · simp only [isolatedRule, if_pos hlong]
      exact isolateOutput_allNonterminals oldRule.output
    · simp only [isolatedRule, if_neg hlong,
        ContextFreeRule.mapNonterminal] at hlen ⊢
      exfalso
      apply hlong
      simpa [ContextFreeRule.mapNonterminal] using hlen
  · simp [terminalIsolationRule] at hlen

@[grind] theorem binarize_language (g : ContextFreeGrammar T)
    [DecidableEq T] [DecidableEq g.NT]
    (hall : ∀ r ∈ g.rules, 2 ≤ r.output.length →
      allNonterminals r.output) :
    (binarize g).language = g.language :=
  le_antisymm (binarize_language_reverse g)
    (binarize_language_forward g hall)


```

## Chomsky 標準形変換の合成

各中間変換と不変条件を順に合成して `ChomskyNormalGrammar` を構成する。必要な線形順序の instance を公開し、最終文法の言語が入力文法と等しいことを API 定理としてまとめる。

```lean
/-- Computably convert a context-free grammar to Chomsky normal form. -/
def toChomskyNormalGrammar {T : Type} [DecidableEq T]
    (g : ContextFreeGrammar T) [DecidableEq g.NT] :
    ChomskyNormalGrammar T := by
  let g₁ := freshStart g
  letI : DecidableEq g₁.NT := by
    change DecidableEq (FreshStartNT g.NT)
    infer_instance
  let g₂ := removeEpsilon g₁
  letI : DecidableEq g₂.NT := by
    change DecidableEq g₁.NT
    infer_instance
  let g₃ := removeUnit g₂
  letI : DecidableEq g₃.NT := by
    change DecidableEq g₂.NT
    infer_instance
  let g₄ := isolateTerminals g₃
  letI : DecidableEq g₄.NT := by
    change DecidableEq (IsolateNT T g₃.NT)
    infer_instance
  let g₅ := binarize g₄
  have hnot₁ := freshStart_initial_not_output g
  have hnot₂ := removeEpsilon_initial_not_output g₁ hnot₁
  have hnot₃ := removeUnit_initial_not_output g₂ hnot₂
  have hnot₄ := isolateTerminals_initial_not_output g₃ hnot₃
  have hε₂ := removeEpsilon_no_noninitial_empty g₁
  have hε₃ := removeUnit_no_noninitial_empty g₂ hε₂ hnot₂
  have hε₄ := isolateTerminals_no_noninitial_empty g₃ hε₃
  have hunit₃ := removeUnit_no_unit g₂
  have hunit₄ := isolateTerminals_no_unit g₃ hunit₃
  have hall₄ := isolateTerminals_long_rhs_all_nonterminals g₃
  exact
    { cfg := g₅
      chomskyNormal := binarize_is_chomsky g₄ hε₄ hunit₄ hall₄
      initial_not_output :=
        binarize_initial_not_output g₄ hnot₄ }

/-- The generated nonterminal type of the computable Chomsky conversion
inherits a computable linear order. -/
@[reducible] def toChomskyNormalGrammarNTLinearOrder {T : Type}
    [LinearOrder T] (g : ContextFreeGrammar T) [LinearOrder g.NT] :
    LinearOrder (toChomskyNormalGrammar g).cfg.NT := by
  let g₁ := freshStart g
  letI : LinearOrder g₁.NT := by
    change LinearOrder (FreshStartNT g.NT)
    infer_instance
  let g₂ := removeEpsilon g₁
  letI : LinearOrder g₂.NT := by
    change LinearOrder g₁.NT
    infer_instance
  let g₃ := removeUnit g₂
  letI : LinearOrder g₃.NT := by
    change LinearOrder g₂.NT
    infer_instance
  let g₄ := isolateTerminals g₃
  letI : LinearOrder g₄.NT := by
    change LinearOrder (IsolateNT T g₃.NT)
    infer_instance
  change LinearOrder (BinaryNT g₄.NT)
  infer_instance

@[important, grind =, simp] theorem toChomskyNormalGrammar_language {T : Type}
    [DecidableEq T] (g : ContextFreeGrammar T) [DecidableEq g.NT] :
    (toChomskyNormalGrammar g).language = g.language := by
  let g₁ := freshStart g
  letI : DecidableEq g₁.NT := by
    change DecidableEq (FreshStartNT g.NT)
    infer_instance
  let g₂ := removeEpsilon g₁
  letI : DecidableEq g₂.NT := by
    change DecidableEq g₁.NT
    infer_instance
  let g₃ := removeUnit g₂
  letI : DecidableEq g₃.NT := by
    change DecidableEq g₂.NT
    infer_instance
  let g₄ := isolateTerminals g₃
  letI : DecidableEq g₄.NT := by
    change DecidableEq (IsolateNT T g₃.NT)
    infer_instance
  have hall₄ := isolateTerminals_long_rhs_all_nonterminals g₃
  calc
    (toChomskyNormalGrammar g).language =
        (binarize g₄).language := rfl
    _ = g₄.language := binarize_language g₄ hall₄
    _ = g₃.language := isolateTerminals_language g₃
    _ = g₂.language := removeUnit_language g₂
    _ = g₁.language := removeEpsilon_language g₁
    _ = g.language := freshStart_language g


end ContextFreeGrammar

end Mathling.Grammar

